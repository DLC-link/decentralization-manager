# Per-participant configuration for dec-party-manager #2.
#
# Copy this file to `.env` next to it (i.e. `cp .env.example .env`) and fill in
# the placeholders. The real `.env` is gitignored — never commit it.
#
# Used by:
#   - `integration-tests/run.sh --target devnet` (see the "Integration tests
#     on devnet" section in README.md for the full prerequisite list).
#   - The deployed-DPM startup scripts that read the DECPM_* keys directly.

# ---------------------------------------------------------------------------
# DPM listener + Canton admin/ledger endpoints (deployment config).
# Defaults assume the standard kubectl-tunnel layout for participant-2.
# ---------------------------------------------------------------------------
DECPM_LISTEN_ADDRESS=0.0.0.0
DECPM_NOISE_PORT=9001
DECPM_PUBLIC_ADDRESS=localhost
DECPM_CANTON_ADMIN_HOST=localhost
DECPM_CANTON_ADMIN_PORT=5012
DECPM_CANTON_LEDGER_HOST=localhost
DECPM_CANTON_LEDGER_PORT=5011
DECPM_CANTON_SYNCHRONIZER=global
DECPM_CANTON_NETWORK=devnet

# ---------------------------------------------------------------------------
# Shared Keycloak (same values across all three participants' .env files).
# DECPM_KEYCLOAK_URL may be configured with or without the trailing `/auth`
# servlet path — both forms are tolerated by src/auth/mod.rs::token_url
# (and by the smoke check in integration-tests/devnet.env.sh).
# ---------------------------------------------------------------------------
DECPM_KEYCLOAK_URL=https://<your-keycloak-host>/auth
DECPM_KEYCLOAK_REALM=<your-realm>
DECPM_KEYCLOAK_CLIENT_ID=<password-grant client_id used by the test runner>
DECPM_KEYCLOAK_USERNAME=<password-grant username>
DECPM_KEYCLOAK_PASSWORD=<password-grant password>

# ---------------------------------------------------------------------------
# DPM workflow timeouts. Defaults are sensible for devnet kubectl-tunneled
# latency; only change if you've measured a need.
# ---------------------------------------------------------------------------
DECPM_TIMEOUT_HANDSHAKE=30
DECPM_TIMEOUT_MESSAGE=120
DECPM_TIMEOUT_RETRY_ATTEMPTS=3
DECPM_TIMEOUT_RETRY_DELAY=5

# ---------------------------------------------------------------------------
# Per-participant member party + its M2M Keycloak client.
# The member party is the Canton party DPM acts as during workflows. The
# Keycloak client uses the `client_credentials` grant — its service-account
# user must have `CanActAs` on the member party (one-time provisioning).
# Format: `<party-prefix>::<32-byte-namespace-fingerprint-hex>`.
# ---------------------------------------------------------------------------
P2_MEMBER_PARTY_ID=attestor-2::<namespace-fingerprint-hex>
P2_MEMBER_USER_ID=attestorUser2
P2_MEMBER_KEYCLOAK_CLIENT_ID=<member M2M client_id>
P2_MEMBER_KEYCLOAK_CLIENT_SECRET=<member M2M client_secret>

# ---------------------------------------------------------------------------
# Participant-admin Keycloak client. Used by DPM's POST /auth/grant-rights
# to mint an admin token via client_credentials, then call Canton's
# UserManagementService.GrantUserRights via gRPC. The service-account user
# of this Keycloak client must have `ParticipantAdmin` on Canton — required
# to grant rights for *other* users.
# ---------------------------------------------------------------------------
P2_PARTICIPANT_ADMIN_KEYCLOAK_CLIENT_ID=<participant-admin M2M client_id>
P2_PARTICIPANT_ADMIN_KEYCLOAK_CLIENT_SECRET=<participant-admin M2M client_secret>
