# Keycloak user the UI tests run as (must exist on devnet; Direct Access Grants enabled)
E2E_KC_USERNAME=cvault-finoa-lp-1
E2E_KC_PASSWORD=

# Set to 1 to skip globalSetup bring-up/teardown (stack already running on :8081-8083)
E2E_ASSUME_STACK_UP=

# Standalone iteration: phases 05/06/08 run against an already-onboarded party
# when these are set (otherwise they use the party created by phase 02).
E2E_PARTY_ID=
E2E_PARTY_PREFIX=
