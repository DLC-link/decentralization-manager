module Governance.UtilityCredential.Test.AcceptFreeCredentialTest where

import Daml.Script

import Utility.Credential.App.V0.Model.Offer (CredentialOffer)
import Utility.Credential.App.V0.Service.User
  (UserService(..), UserService_OfferFreeCredential(..))
import Utility.Credential.V0.Credential (Credential(..))

import Governance.Action (GovernableAction)
import Governance.Rules

import Governance.UtilityCredential.AcceptFreeCredential
import Governance.UtilityCredential.TestUtils

import TestHarness

-- | Set up a CredentialOffer where the governance party is the *holder*
-- (so the governance UserService is the side that will accept). We do this
-- with a multi-party submit that bypasses the governance flow on the
-- offering side: the test isn't validating the offer side, only the accept.
data Fixture = Fixture
  with
    parties : CredentialTestParties
    rulesCid : ContractId GovernanceRules
    userServiceCid : ContractId UserService
    offerCid : ContractId CredentialOffer
  deriving (Eq, Show)

-- | Create an `issuerUserService` for an external issuer and offer a free
-- credential where governanceParty is the holder, returning the offer cid.
seedOfferToGovernance : CredentialTestParties -> Script (ContractId CredentialOffer)
seedOfferToGovernance parties = do
  -- The holder party plays the issuer in this seeded offer (acts as the
  -- external issuer's UserService user).
  issuerUserServiceCid <- submit (actAs parties.holder <> actAs parties.operator) $
    createCmd UserService with
      operator = parties.operator
      user = parties.holder
      dso = parties.dso
  result <- submit parties.holder $
    exerciseCmd issuerUserServiceCid UserService_OfferFreeCredential with
      holder = parties.governanceParty
      id = "external-credential"
      description = "External free credential offered to governance"
      claims = [testClaim parties.governanceParty]
  pure result.credentialOfferCid

given_governance_with_offer : Script Fixture
given_governance_with_offer = do
  parties <- allocateCredentialTestParties
  rulesCid <- createTestGovernance parties
  userServiceCid <- initUserService parties
  offerCid <- seedOfferToGovernance parties
  pure Fixture with ..

-- * Happy path: propose-confirm-execute creates a Credential.

when_accept_free_executed : Fixture -> Script ()
when_accept_free_executed f = do
  proposalCid <- submit f.parties.member1 $ createCmd AcceptFreeCredential with
    governanceParty = f.parties.governanceParty
    proposer = f.parties.member1
    userServiceCid = f.userServiceCid
    credentialOfferCid = f.offerCid
  let proposalInterfaceCid : ContractId GovernableAction = toInterfaceContractId proposalCid
  _ <- confirmAndExecute f.parties f.rulesCid proposalInterfaceCid
    [f.parties.member1, f.parties.member2] f.parties.member1
  pure ()

then_credential_exists : Fixture -> () -> Script Failures
then_credential_exists f _ = do
  creds <- query @Credential f.parties.governanceParty
  case creds of
    [(_, cred)] -> pure $
      shouldBe "issuer is external holder" f.parties.holder cred.issuer <>
      shouldBe "holder is governance" f.parties.governanceParty cred.holder <>
      shouldBe "id" "external-credential" cred.id <>
      shouldBe "claims count" 1 (length cred.claims)
    _ -> pure $ shouldBe "Credential count" 1 (length creds)

test_when_accept_free_proposed_and_confirmed_then_credential_exists = script do
  run Test with
    given = given_governance_with_offer
    when = when_accept_free_executed
    then_ = then_credential_exists

-- * Non-member confirm is rejected.

when_outsider_confirms_accept : Fixture -> Script ()
when_outsider_confirms_accept f = do
  proposalCid <- submit f.parties.member1 $ createCmd AcceptFreeCredential with
    governanceParty = f.parties.governanceParty
    proposer = f.parties.member1
    userServiceCid = f.userServiceCid
    credentialOfferCid = f.offerCid
  let proposalInterfaceCid : ContractId GovernableAction = toInterfaceContractId proposalCid
  submitMustFail (memberContext f.parties.outsider f.parties.governanceParty) $
    exerciseCmd f.rulesCid GovernanceRules_ConfirmAction with
      confirmer = f.parties.outsider
      actionProposalCid = proposalInterfaceCid

then_nothing : Fixture -> () -> Script Failures
then_nothing _ _ = pure []

test_when_outsider_confirms_accept_free_then_rejected = script do
  run Test with
    given = given_governance_with_offer
    when = when_outsider_confirms_accept
    then_ = then_nothing
