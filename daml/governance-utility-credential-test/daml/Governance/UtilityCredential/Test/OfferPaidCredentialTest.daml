-- | Smoke coverage for OfferPaidCredential. We only verify that the proposal
-- reaches `UserService_OfferPaidCredential` and produces a paid CredentialOffer
-- (`billingParams = Some _`). Distribution / top-up / billing logic is owned
-- by the credential-app and not re-tested here.
module Governance.UtilityCredential.Test.OfferPaidCredentialTest where

import DA.Optional (isSome)
import Daml.Script

import Utility.Credential.App.V0.Model.Offer (CredentialOffer(..))
import Utility.Credential.App.V0.Service.User (UserService)
import Utility.Credential.App.V0.Types (BillingParams(..), RatePerDay(..))

import Governance.Action (GovernableAction)
import Governance.Rules

import Governance.UtilityCredential.OfferPaidCredential
import Governance.UtilityCredential.TestUtils

import TestHarness

data Fixture = Fixture
  with
    parties : CredentialTestParties
    rulesCid : ContractId GovernanceRules
    userServiceCid : ContractId UserService
  deriving (Eq, Show)

given_governance_with_user_service : Script Fixture
given_governance_with_user_service = do
  parties <- allocateCredentialTestParties
  rulesCid <- createTestGovernance parties
  userServiceCid <- initUserService parties
  pure Fixture with ..

testBillingParams : BillingParams
testBillingParams = BillingParams with
  feePerDayUsd = RatePerDay with rate = 1.0
  billingPeriodMinutes = 60
  depositTargetAmountUsd = 30.0
  holderActivityWeight = None

when_offer_paid_executed : Fixture -> Script ()
when_offer_paid_executed f = do
  proposalCid <- submit f.parties.member1 $ createCmd OfferPaidCredential with
    governanceParty = f.parties.governanceParty
    proposer = f.parties.member1
    userServiceCid = f.userServiceCid
    holder = f.parties.holder
    id = "paid-credential"
    description = "Test paid credential"
    claims = [testClaim f.parties.holder]
    billingParams = testBillingParams
    depositInitialAmountUsd = None
  let proposalInterfaceCid : ContractId GovernableAction = toInterfaceContractId proposalCid
  _ <- confirmAndExecute f.parties f.rulesCid proposalInterfaceCid
    [f.parties.member1, f.parties.member2] f.parties.member1
  pure ()

then_paid_offer_created : Fixture -> () -> Script Failures
then_paid_offer_created f _ = do
  offers <- query @CredentialOffer f.parties.governanceParty
  case offers of
    [(_, offer)] -> pure $
      shouldBe "issuer" f.parties.governanceParty offer.issuer <>
      shouldBe "holder" f.parties.holder offer.holder <>
      shouldBe "id" "paid-credential" offer.id <>
      shouldBe "billingParams is Some" True (isSome offer.billingParams)
    _ -> pure $ shouldBe "CredentialOffer count" 1 (length offers)

test_when_offer_paid_proposed_and_confirmed_then_paid_offer_created = script do
  run Test with
    given = given_governance_with_user_service
    when = when_offer_paid_executed
    then_ = then_paid_offer_created
