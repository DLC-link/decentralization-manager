module Governance.UtilityCredential.Test.OfferFreeCredentialTest where

import DA.Optional (isNone)
import Daml.Script

import Utility.Credential.App.V0.Model.Offer (CredentialOffer(..))
import Utility.Credential.App.V0.Service.User (UserService)

import Governance.Action (GovernableAction)
import Governance.Rules

import Governance.UtilityCredential.OfferFreeCredential
import Governance.UtilityCredential.TestUtils

import TestHarness

data Fixture = Fixture
  with
    parties : CredentialTestParties
    rulesCid : ContractId GovernanceRules
    userServiceCid : ContractId UserService
  deriving (Eq, Show)

given_governance_with_user_service : Script Fixture
given_governance_with_user_service = do
  parties <- allocateCredentialTestParties
  rulesCid <- createTestGovernance parties
  userServiceCid <- initUserService parties
  pure Fixture with ..

-- * Happy path: propose → confirm → execute → assert offer created.

when_offer_free_executed : Fixture -> Script ()
when_offer_free_executed f = do
  proposalCid <- submit f.parties.member1 $ createCmd OfferFreeCredential with
    governanceParty = f.parties.governanceParty
    proposer = f.parties.member1
    userServiceCid = f.userServiceCid
    holder = f.parties.holder
    id = "test-credential"
    description = "Test free credential"
    claims = [testClaim f.parties.holder]
  let proposalInterfaceCid : ContractId GovernableAction = toInterfaceContractId proposalCid
  _ <- confirmAndExecute f.parties f.rulesCid proposalInterfaceCid
    [f.parties.member1, f.parties.member2] f.parties.member1
  pure ()

then_free_offer_created : Fixture -> () -> Script Failures
then_free_offer_created f _ = do
  offers <- query @CredentialOffer f.parties.governanceParty
  case offers of
    [(_, offer)] -> pure $
      shouldBe "issuer" f.parties.governanceParty offer.issuer <>
      shouldBe "holder" f.parties.holder offer.holder <>
      shouldBe "id" "test-credential" offer.id <>
      shouldBe "description" "Test free credential" offer.description <>
      shouldBe "claims count" 1 (length offer.claims) <>
      shouldBe "billingParams is None" True (isNone offer.billingParams)
    _ -> pure $ shouldBe "CredentialOffer count" 1 (length offers)

test_when_offer_free_proposed_and_confirmed_then_offer_created = script do
  run Test with
    given = given_governance_with_user_service
    when = when_offer_free_executed
    then_ = then_free_offer_created

-- * Non-member confirm is rejected.

when_outsider_confirms : Fixture -> Script ()
when_outsider_confirms f = do
  proposalCid <- submit f.parties.member1 $ createCmd OfferFreeCredential with
    governanceParty = f.parties.governanceParty
    proposer = f.parties.member1
    userServiceCid = f.userServiceCid
    holder = f.parties.holder
    id = "test-credential"
    description = "Test free credential"
    claims = [testClaim f.parties.holder]
  let proposalInterfaceCid : ContractId GovernableAction = toInterfaceContractId proposalCid
  submitMustFail (memberContext f.parties.outsider f.parties.governanceParty) $
    exerciseCmd f.rulesCid GovernanceRules_ConfirmAction with
      confirmer = f.parties.outsider
      actionProposalCid = proposalInterfaceCid

then_nothing : Fixture -> () -> Script Failures
then_nothing _ _ = pure []

test_when_outsider_confirms_offer_free_then_rejected = script do
  run Test with
    given = given_governance_with_user_service
    when = when_outsider_confirms
    then_ = then_nothing
