-- * SetProviderAppRewardBeneficiaries

when_set_beneficiaries : SetupFixture -> Script ()
when_set_beneficiaries f = do
  proposalCid <- submit f.parties.member1 $ createCmd SetProviderAppRewardBeneficiaries with
    governanceParty = f.parties.governanceParty
    governanceId = testGovernanceId
    proposer = f.parties.member1
    instrumentConfigurationCid = f.artifacts.instrumentConfigurationCid
    providerAppRewardBeneficiaries = None
  let proposalInterfaceCid : ContractId GovernableAction = toInterfaceContractId proposalCid
  _ <- confirmAndExecute f.parties f.rulesCid proposalInterfaceCid
    [f.parties.member1, f.parties.member2] f.parties.member1
  pure ()

then_beneficiaries_cleared : SetupFixture -> () -> Script Failures
then_beneficiaries_cleared f _ = do
  configs <- query @InstrumentConfiguration f.parties.governanceParty
  case configs of
    [(_, config)] -> pure $
      shouldBe "providerAppRewardBeneficiaries" None config.providerAppRewardBeneficiaries
    _ -> pure $ shouldBe "InstrumentConfiguration count" 1 (length configs)

test_set_provider_app_reward_beneficiaries = script do
  run Test with
    given = given_setup_done
    when = when_set_beneficiaries
    then_ = then_beneficiaries_cleared

-- * SetEnableResultContracts

when_set_enable_result_contracts : SetupFixture -> Script ()
when_set_enable_result_contracts f = do
  proposalCid <- submit f.parties.member1 $ createCmd SetEnableResultContracts with
    governanceParty = f.parties.governanceParty
    governanceId = testGovernanceId
    proposer = f.parties.member1
    registrarServiceCid = f.artifacts.registrarServiceCid
    enableResultContracts = Some True
  let proposalInterfaceCid : ContractId GovernableAction = toInterfaceContractId proposalCid
  _ <- confirmAndExecute f.parties f.rulesCid proposalInterfaceCid
    [f.parties.member1, f.parties.member2] f.parties.member1
  pure ()

then_enable_result_contracts_set : SetupFixture -> () -> Script Failures
then_enable_result_contracts_set f _ = do
  services <- query @RegistrarService f.parties.governanceParty
  case services of
    [(_, svc)] -> pure $
      shouldBe "enableResultContracts" (Some True) svc.enableResultContracts
    _ -> pure $ shouldBe "RegistrarService count" 1 (length services)

test_set_enable_result_contracts = script do
  run Test with
    given = given_setup_done
    when = when_set_enable_result_contracts
    then_ = then_enable_result_contracts_set

