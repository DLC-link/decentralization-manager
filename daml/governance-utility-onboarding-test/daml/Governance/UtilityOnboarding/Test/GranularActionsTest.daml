-- | Tests for granular onboarding actions.
module Governance.UtilityOnboarding.Test.GranularActionsTest where

import DA.Set as Set hiding (filter)
import DA.Time (minutes)
import Daml.Script

import Utility.Commercials.V0.Model.DelegatedBatchedMarkersProxy (DelegatedBatchedMarkersProxy)
import Utility.Credential.App.V0.Service.User (UserServiceRequest)
import Utility.Registry.App.V0.Service.Provider (ProviderService, ProviderServiceRequest)
import Utility.Registry.App.V0.Service.Registrar (RegistrarService(..))
import Utility.Registry.V0.Configuration.Instrument (InstrumentConfiguration(..))

import Governance.Action (GovernableAction)
import Governance.Rules

import Governance.UtilityOnboarding.CreateDelegatedBatchedMarkersProxy
import Governance.UtilityOnboarding.CreateProviderServiceRequest
import Governance.UtilityOnboarding.CreateUserServiceRequest
import Governance.UtilityOnboarding.ProvisionProviderService
import Governance.UtilityOnboarding.SetEnableResultContracts
import Governance.UtilityOnboarding.SetProviderAppRewardBeneficiaries
import Governance.UtilityOnboarding.TestUtils

import TestHarness

data GovFixture = GovFixture
  with
    parties : OnboardingTestParties
    rulesCid : ContractId GovernanceRules
  deriving (Eq, Show)

given_governance : Script GovFixture
given_governance = do
  parties <- allocateOnboardingTestParties
  rulesCid <- createTestGovernance parties
  pure GovFixture with ..

data SetupFixture = SetupFixture
  with
    parties : OnboardingTestParties
    rulesCid : ContractId GovernanceRules
    artifacts : SetupArtifacts
  deriving (Eq, Show)

given_setup_done : Script SetupFixture
given_setup_done = do
  parties <- allocateOnboardingTestParties
  rulesCid <- createTestGovernance parties
  artifacts <- setupUtilityForTest parties rulesCid
  pure SetupFixture with ..

-- * ProvisionProviderService
--
-- The operator party is the proposer, so the operator's authority flows via
-- `signatory proposer` into executeImpl where the ProviderService is created
-- with `operator = proposer, provider = governanceParty`.
-- The operator must be listed as an additional proposer since it is not a member.

given_governance_with_operator_as_additional_proposer : Script GovFixture
given_governance_with_operator_as_additional_proposer = do
  parties <- allocateOnboardingTestParties
  rulesCid <- submit parties.governanceParty $ createCmd GovernanceRules with
    governanceParty = parties.governanceParty
    governanceId = testGovernanceId
    members = getMembers parties
    threshold = 2
    actionConfirmationTimeout = minutes 30
    additionalProposers = Some (Set.singleton parties.operator)
  pure GovFixture with ..

when_provision_provider_service : GovFixture -> Script ()
when_provision_provider_service f = do
  proposalCid <- submit f.parties.operator $ createCmd ProvisionProviderService with
    governanceParty = f.parties.governanceParty
    governanceId = testGovernanceId
    proposer = f.parties.operator
  let proposalInterfaceCid : ContractId GovernableAction = toInterfaceContractId proposalCid
  _ <- confirmAndExecute f.parties f.rulesCid proposalInterfaceCid
    [f.parties.member1, f.parties.member2] f.parties.member1
  pure ()

then_provider_service_exists : GovFixture -> () -> Script Failures
then_provider_service_exists f _ = do
  services <- query @ProviderService f.parties.governanceParty
  pure $ shouldBe "ProviderService count" 1 (length services)

test_provision_provider_service = script do
  run Test with
    given = given_governance_with_operator_as_additional_proposer
    when = when_provision_provider_service
    then_ = then_provider_service_exists

-- * CreateProviderServiceRequest

when_create_provider_service_request : GovFixture -> Script ()
when_create_provider_service_request f = do
  proposalCid <- submit f.parties.member1 $ createCmd CreateProviderServiceRequest with
    governanceParty = f.parties.governanceParty
    governanceId = testGovernanceId
    proposer = f.parties.member1
    operator = f.parties.operator
    provider = f.parties.governanceParty
  let proposalInterfaceCid : ContractId GovernableAction = toInterfaceContractId proposalCid
  _ <- confirmAndExecute f.parties f.rulesCid proposalInterfaceCid
    [f.parties.member1, f.parties.member2] f.parties.member1
  pure ()

then_provider_service_request_exists : GovFixture -> () -> Script Failures
then_provider_service_request_exists f _ = do
  requests <- query @ProviderServiceRequest f.parties.governanceParty
  pure $ shouldBe "ProviderServiceRequest count" 1 (length requests)

test_create_provider_service_request = script do
  run Test with
    given = given_governance
    when = when_create_provider_service_request
    then_ = then_provider_service_request_exists

