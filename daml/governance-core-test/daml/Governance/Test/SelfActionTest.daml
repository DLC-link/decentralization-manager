-- | Tests for governance self-management actions (built-in path).
module Governance.Test.SelfActionTest where

import DA.Assert
import DA.Optional (fromOptional)
import DA.Set as Set hiding (filter)
import DA.Time (minutes, seconds)
import Daml.Script

import Governance.Rules
import Governance.TestUtils

-- | Add a member via self-action confirm → execute flow.
testAddMember = script do
  parties <- allocateTestParties
  rulesCid <- createTestGovernance parties
  newMember <- allocateParty "NewMember"

  let action = SelfAction_AddMemberAndSetThreshold with
        newMember
        newThresholdAfterAdd = 3

  _newRulesCid <- confirmAndExecuteSelf parties rulesCid action
    [parties.member1, parties.member2] parties.member1

  [(_, rules)] <- query @GovernanceRules parties.governanceParty
  assertMsg "New member should be in the set" (newMember `Set.member` rules.members)
  rules.threshold === 3
  Set.size rules.members === 4

-- | Remove a member via self-action confirm → execute flow.
testRemoveMember = script do
  parties <- allocateTestParties
  rulesCid <- createTestGovernance parties

  let action = SelfAction_RemoveMemberAndSetThreshold with
        removedMember = parties.member3
        newThresholdAfterRemove = 2

  _newRulesCid <- confirmAndExecuteSelf parties rulesCid action
    [parties.member1, parties.member2] parties.member1

  [(_, rules)] <- query @GovernanceRules parties.governanceParty
  assertMsg "Removed member should not be in the set" (parties.member3 `Set.notMember` rules.members)
  Set.size rules.members === 2

-- | Set threshold via self-action.
testSetThreshold = script do
  parties <- allocateTestParties
  rulesCid <- createTestGovernance parties

  let action = SelfAction_SetThreshold with updatedThreshold = 3

  _newRulesCid <- confirmAndExecuteSelf parties rulesCid action
    [parties.member1, parties.member2] parties.member1

  [(_, rules)] <- query @GovernanceRules parties.governanceParty
  rules.threshold === 3

-- | Reject threshold exceeding member count.
testRejectThresholdExceedingMembers = script do
  parties <- allocateTestParties
  rulesCid <- createTestGovernance parties

  let action = SelfAction_SetThreshold with updatedThreshold = 4

  confirmationCids <- submitSelfConfirmations parties.governanceParty rulesCid action
    [parties.member1, parties.member2]

  submitMustFail (memberContext parties.member1 parties.governanceParty) $
    exerciseCmd rulesCid GovernanceRules_ExecuteGovernanceAction with
      executor = parties.member1
      action
      confirmations = confirmationCids

-- | Reject threshold less than 1 (zero or negative).
testRejectThresholdLessThanOne = script do
  parties <- allocateTestParties
  rulesCid <- createTestGovernance parties

  let action = SelfAction_SetThreshold with updatedThreshold = 0

  confirmationCids <- submitSelfConfirmations parties.governanceParty rulesCid action
    [parties.member1, parties.member2]

  submitMustFail (memberContext parties.member1 parties.governanceParty) $
    exerciseCmd rulesCid GovernanceRules_ExecuteGovernanceAction with
      executor = parties.member1
      action
      confirmations = confirmationCids

-- | Set action confirmation timeout.
testSetTimeout = script do
  parties <- allocateTestParties
  rulesCid <- createTestGovernance parties

  let action = SelfAction_SetTimeout with updatedTimeout = minutes 60

  _newRulesCid <- confirmAndExecuteSelf parties rulesCid action
    [parties.member1, parties.member2] parties.member1

  [(_, rules)] <- query @GovernanceRules parties.governanceParty
  rules.actionConfirmationTimeout === minutes 60

-- | Reject timeout less than 10 seconds.
testRejectShortTimeout = script do
  parties <- allocateTestParties
  rulesCid <- createTestGovernance parties

  let action = SelfAction_SetTimeout with updatedTimeout = seconds 5

  confirmationCids <- submitSelfConfirmations parties.governanceParty rulesCid action
    [parties.member1, parties.member2]

  submitMustFail (memberContext parties.member1 parties.governanceParty) $
    exerciseCmd rulesCid GovernanceRules_ExecuteGovernanceAction with
      executor = parties.member1
      action
      confirmations = confirmationCids

-- | Non-member cannot confirm self-action.
testNonMemberCannotConfirmSelfAction = script do
  parties <- allocateTestParties
  rulesCid <- createTestGovernance parties

  let action = SelfAction_SetThreshold with updatedThreshold = 3

  submitMustFail (memberContext parties.outsider parties.governanceParty) $
    exerciseCmd rulesCid GovernanceRules_ConfirmGovernanceAction with
      confirmer = parties.outsider
      action

-- | Non-member cannot execute self-action.
testNonMemberCannotExecuteSelfAction = script do
  parties <- allocateTestParties
  rulesCid <- createTestGovernance parties

  let action = SelfAction_SetThreshold with updatedThreshold = 3

  confirmationCids <- submitSelfConfirmations parties.governanceParty rulesCid action
    [parties.member1, parties.member2]

  submitMustFail (memberContext parties.outsider parties.governanceParty) $
    exerciseCmd rulesCid GovernanceRules_ExecuteGovernanceAction with
      executor = parties.outsider
      action
      confirmations = confirmationCids

-- | Insufficient confirmations for self-action.
testInsufficientSelfConfirmations = script do
  parties <- allocateTestParties
  rulesCid <- createTestGovernance parties

  let action = SelfAction_SetThreshold with updatedThreshold = 3

  confirmationCids <- submitSelfConfirmations parties.governanceParty rulesCid action
    [parties.member1]

  submitMustFail (memberContext parties.member1 parties.governanceParty) $
    exerciseCmd rulesCid GovernanceRules_ExecuteGovernanceAction with
      executor = parties.member1
      action
      confirmations = confirmationCids

-- | Mismatched action in confirmations.
testMismatchedSelfAction = script do
  parties <- allocateTestParties
  rulesCid <- createTestGovernance parties

  let actionA = SelfAction_SetThreshold with updatedThreshold = 3
  let actionB = SelfAction_SetThreshold with updatedThreshold = 2

  confResultA <- submit (memberContext parties.member1 parties.governanceParty) $
    exerciseCmd rulesCid GovernanceRules_ConfirmGovernanceAction with
      confirmer = parties.member1
      action = actionA

  confResultB <- submit (memberContext parties.member2 parties.governanceParty) $
    exerciseCmd rulesCid GovernanceRules_ConfirmGovernanceAction with
      confirmer = parties.member2
      action = actionB

  submitMustFail (memberContext parties.member1 parties.governanceParty) $
    exerciseCmd rulesCid GovernanceRules_ExecuteGovernanceAction with
      executor = parties.member1
      action = actionA
      confirmations = [confResultA.confirmationCid, confResultB.confirmationCid]

-- | Add an additional proposer via self-action confirm → execute flow.
testAddAdditionalProposer = script do
  parties <- allocateTestParties
  rulesCid <- createTestGovernance parties

  let action = SelfAction_AddAdditionalProposer with
        additionalProposer = parties.outsider

  _newRulesCid <- confirmAndExecuteSelf parties rulesCid action
    [parties.member1, parties.member2] parties.member1

  [(_, rules)] <- query @GovernanceRules parties.governanceParty
  let aps = fromOptional Set.empty rules.additionalProposers
  assertMsg "outsider should be in additionalProposers"
    (parties.outsider `Set.member` aps)
  Set.size aps === 1

-- | Remove an additional proposer via self-action confirm → execute flow.
testRemoveAdditionalProposer = script do
  parties <- allocateTestParties

  -- Start with `outsider` already in additionalProposers.
  rulesCid <- submit parties.governanceParty $ createCmd GovernanceRules with
    governanceParty = parties.governanceParty
    members = getMembers parties
    threshold = 2
    actionConfirmationTimeout = minutes 30
    additionalProposers = Some (Set.singleton parties.outsider)

  let action = SelfAction_RemoveAdditionalProposer with
        additionalProposer = parties.outsider

  _newRulesCid <- confirmAndExecuteSelf parties rulesCid action
    [parties.member1, parties.member2] parties.member1

  [(_, rules)] <- query @GovernanceRules parties.governanceParty
  let aps = fromOptional Set.empty rules.additionalProposers
  assertMsg "outsider should be removed"
    (parties.outsider `Set.notMember` aps)
  Set.size aps === 0
  assertMsg "additionalProposers should normalize to None when empty"
    (rules.additionalProposers == None)

-- | An `additionalProposer` may seed a `GovernanceSelfConfirmation` to put
-- a self-action proposal on the ledger for members to observe. The marker
-- coexists with member votes and is filtered out at execute time so it does
-- not count toward the threshold.
testAdditionalProposerSeedsSelfAction = script do
  parties <- allocateTestParties

  rulesCid <- submit parties.governanceParty $ createCmd GovernanceRules with
    governanceParty = parties.governanceParty
    members = getMembers parties
    threshold = 2
    actionConfirmationTimeout = minutes 30
    additionalProposers = Some (Set.singleton parties.outsider)

  let action = SelfAction_SetThreshold with updatedThreshold = 3

  seed <- submit (memberContext parties.outsider parties.governanceParty) $
    exerciseCmd rulesCid GovernanceRules_ConfirmGovernanceAction with
      confirmer = parties.outsider
      action

  memberConfirmations <- submitSelfConfirmations parties.governanceParty rulesCid action
    [parties.member1, parties.member2]

  _ <- submit (memberContext parties.member1 parties.governanceParty) $
    exerciseCmd rulesCid GovernanceRules_ExecuteGovernanceAction with
      executor = parties.member1
      action
      confirmations = seed.confirmationCid :: memberConfirmations

  [(_, rules)] <- query @GovernanceRules parties.governanceParty
  rules.threshold === 3

-- | An `additionalProposer` marker on its own (no member votes) is not enough
-- to execute — only member confirmations count toward threshold.
testAdditionalProposerAloneCannotExecute = script do
  parties <- allocateTestParties

  rulesCid <- submit parties.governanceParty $ createCmd GovernanceRules with
    governanceParty = parties.governanceParty
    members = getMembers parties
    threshold = 2
    actionConfirmationTimeout = minutes 30
    additionalProposers = Some (Set.singleton parties.outsider)

  let action = SelfAction_SetThreshold with updatedThreshold = 3

  seed <- submit (memberContext parties.outsider parties.governanceParty) $
    exerciseCmd rulesCid GovernanceRules_ConfirmGovernanceAction with
      confirmer = parties.outsider
      action

  submitMustFail (memberContext parties.member1 parties.governanceParty) $
    exerciseCmd rulesCid GovernanceRules_ExecuteGovernanceAction with
      executor = parties.member1
      action
      confirmations = [seed.confirmationCid]

-- | A party that is neither a member nor an `additionalProposer` still
-- cannot confirm — the relaxation only widens the gate to the allowlist.
testStrangerCannotConfirmSelfAction = script do
  parties <- allocateTestParties
  somePropParty <- allocateParty "AllowedProposer"

  rulesCid <- submit parties.governanceParty $ createCmd GovernanceRules with
    governanceParty = parties.governanceParty
    members = getMembers parties
    threshold = 2
    actionConfirmationTimeout = minutes 30
    additionalProposers = Some (Set.singleton somePropParty)

  let action = SelfAction_SetThreshold with updatedThreshold = 3

  submitMustFail (memberContext parties.outsider parties.governanceParty) $
    exerciseCmd rulesCid GovernanceRules_ConfirmGovernanceAction with
      confirmer = parties.outsider
      action
