# justfile for the dec-party-manager Daml packages

# Default recipe: list available recipes.
default:
	@just --list

# Build all Daml packages.
build:
	daml build --all

# Build only the token-issuance plugin and its test package.
build-issuance:
	cd governance-token-issuance && daml build
	cd governance-token-issuance-test && daml build

# Run the token-issuance test suite.
test-issuance:
	cd governance-token-issuance-test && daml test

# Start a local sandbox on port 6865 (run in a separate terminal).
sandbox:
	daml sandbox --port 6865

# Upload the token-issuance DARs (and governance-core) to the running sandbox.
# `daml script` auto-uploads only its top DAR, not transitive dependencies, so
# `governance-core-v0-rc2` has to be vetted explicitly before the script runs.
upload-dars: build-issuance
	daml ledger upload-dar --host localhost --port 6865 governance-core/.daml/dist/governance-core-v0-rc2-0.1.0.dar
	daml ledger upload-dar --host localhost --port 6865 governance-token-issuance/.daml/dist/governance-token-issuance-v0-rc2-0.1.0.dar
	daml ledger upload-dar --host localhost --port 6865 governance-token-issuance-test/.daml/dist/governance-token-issuance-test-0.1.0.dar

# Populate a running sandbox with a freshly-issued test instrument plus a
# MintOffer for `outsider`. Assumes `just sandbox` (or equivalent) is running
# on localhost:6865 with a clean state — the script calls `allocateParty` with
# named hints and will fail if those parties already exist from a prior run.
populate-sandbox: upload-dars
	daml script \
	  --dar governance-token-issuance-test/.daml/dist/governance-token-issuance-test-0.1.0.dar \
	  --script-name Governance.TokenIssuance.Scripts.PopulateSandbox:populate \
	  --ledger-host localhost \
	  --ledger-port 6865 \
	  --wall-clock-time

# Clean Daml build artefacts for token-issuance packages.
clean-issuance:
	rm -rf governance-token-issuance/.daml governance-token-issuance-test/.daml
