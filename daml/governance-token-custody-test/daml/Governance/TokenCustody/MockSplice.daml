-- | Mock implementations of Splice token standard interfaces for testing.
-- These templates implement TransferFactory, TransferInstruction, and Holding
-- without depending on real token registry infrastructure.
module Governance.TokenCustody.MockSplice where

import DA.TextMap qualified as TM

import Splice.Api.Token.HoldingV1
import Splice.Api.Token.MetadataV1 (Metadata(..), emptyMetadata)
import Splice.Api.Token.TransferInstructionV1

-- | Witness that a mock transfer was executed.
template MockTransferResult
  with
    admin : Party
    sender : Party
    receiver : Party
    amount : Decimal
  where
    signatory admin, sender

-- | Witness that a mock transfer was accepted.
template MockAcceptResult
  with
    sender : Party
    receiver : Party
  where
    signatory sender, receiver

-- | Mock implementation of the Holding interface.
-- Represents a simple token holding for testing.
template MockHolding
  with
    owner : Party
    instrumentAdmin : Party
    instrumentIdText : Text
    holdingAmount : Decimal
  where
    signatory owner
    observer instrumentAdmin

    interface instance Holding for MockHolding where
      view = HoldingView with
        owner
        instrumentId = InstrumentId with
          admin = instrumentAdmin
          id = instrumentIdText
        amount = holdingAmount
        lock = None
        meta = Metadata with values = TM.empty

-- | Mock implementation of the TransferFactory interface.
-- Simulates a token factory that accepts transfer requests and creates
-- a MockTransferResult witness.
template MockTransferFactory
  with
    admin : Party
    users : [Party]
      -- ^ Parties that can see and use this factory (e.g., governanceParty).
  where
    signatory admin
    observer users

    interface instance TransferFactory for MockTransferFactory where
      view = TransferFactoryView with
        admin
        meta = emptyMetadata

      transferFactory_transferImpl _self arg = do
        create MockTransferResult with
          admin
          sender = arg.transfer.sender
          receiver = arg.transfer.receiver
          amount = arg.transfer.amount
        pure TransferInstructionResult with
          output = TransferInstructionResult_Completed with
            receiverHoldingCids = []
          senderChangeCids = []
          meta = emptyMetadata

      transferFactory_publicFetchImpl _self _arg = do
        pure TransferFactoryView with
          admin
          meta = emptyMetadata

-- | Mock implementation of the TransferInstruction interface.
-- Simulates a pending transfer that can be accepted, rejected, or withdrawn.
template MockTransferInstruction
  with
    sender : Party
    receiver : Party
    instrumentAdmin : Party
    instrumentIdText : Text
    transferAmount : Decimal
    requestedAt : Time
    executeBefore : Time
  where
    signatory sender
    observer receiver, instrumentAdmin

    interface instance TransferInstruction for MockTransferInstruction where
      view = TransferInstructionView with
        originalInstructionCid = None
        transfer = Transfer with
          sender
          receiver
          amount = transferAmount
          instrumentId = InstrumentId with
            admin = instrumentAdmin
            id = instrumentIdText
          requestedAt
          executeBefore
          inputHoldingCids = []
          meta = emptyMetadata
        status = TransferPendingReceiverAcceptance
        meta = emptyMetadata

      transferInstruction_acceptImpl _self _arg = do
        create MockAcceptResult with
          sender
          receiver
        pure TransferInstructionResult with
          output = TransferInstructionResult_Completed with
            receiverHoldingCids = []
          senderChangeCids = []
          meta = emptyMetadata

      transferInstruction_rejectImpl _self _arg = do
        pure TransferInstructionResult with
          output = TransferInstructionResult_Failed
          senderChangeCids = []
          meta = emptyMetadata

      transferInstruction_withdrawImpl _self _arg = do
        pure TransferInstructionResult with
          output = TransferInstructionResult_Failed
          senderChangeCids = []
          meta = emptyMetadata

      transferInstruction_updateImpl _self _arg = do
        pure TransferInstructionResult with
          output = TransferInstructionResult_Failed
          senderChangeCids = []
          meta = emptyMetadata
