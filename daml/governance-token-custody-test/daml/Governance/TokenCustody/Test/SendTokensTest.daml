-- | Tests for the TransferProposal governable action (SendTokens).
-- SendTokens uses TransferFactory_Transfer on a TransferPreapproval.
module Governance.TokenCustody.Test.SendTokensTest where

import DA.Time (addRelTime, hours)
import Daml.Script

import Splice.Api.Token.HoldingV1 (Holding, InstrumentId)
import Splice.Api.Token.MetadataV1 (ExtraArgs(..), emptyMetadata)
import Splice.Api.Token.TransferInstructionV1 (Transfer(..))

import Utility.Registry.App.V0.Model.TransferPreapproval (TransferPreapproval(..))

import Governance.Action (GovernableAction)
import Governance.Rules (GovernanceRules(..), GovernanceRules_ConfirmAction(..), GovernanceRules_ExecuteConfirmedAction(..))
import Governance.TokenCustody.TransferProposal
import Governance.TokenCustody.TestUtils

import TestHarness
import TestLib.Token (SetupTokenResult(..))
import TestLib.TokenOps (mintTokens, createTransferContext)

-- ============================================================================
-- Fixtures
-- ============================================================================

data SendFixture = SendFixture
  with
    parties : TokenTestParties
    result : SetupTokenResult
    rulesCid : ContractId GovernanceRules
  deriving (Eq, Show)

-- ============================================================================
-- Helpers
-- ============================================================================

-- | Create a TransferPreapproval for the receiver.
createReceiverPreapproval : TokenTestParties -> SetupTokenResult -> Script (ContractId TransferPreapproval)
createReceiverPreapproval parties result =
  submit parties.outsider $ createCmd TransferPreapproval with
    operator = result.operator
    receiver = parties.outsider
    instrumentAdmin = parties.registrar
    instrumentAllowances = []

-- | Build a standard Transfer from governance party to outsider.
buildTestTransfer : TokenTestParties -> InstrumentId -> Time -> Decimal -> [ContractId Holding] -> Transfer
buildTestTransfer parties instrument now amount holdingCids = Transfer with
  sender = parties.governanceParty
  receiver = parties.outsider
  amount
  instrumentId = instrument
  requestedAt = now
  executeBefore = now `addRelTime` hours 24
  inputHoldingCids = holdingCids
  meta = emptyMetadata

-- ============================================================================
-- Given
-- ============================================================================

given_governance_with_token_setup : Script SendFixture
given_governance_with_token_setup = do
  parties <- allocateTokenTestParties
  result <- setupTestToken parties
  rulesCid <- createTestGovernance parties
  pure SendFixture with ..

-- ============================================================================
-- When
-- ============================================================================

when_zero_amount_proposal_creation_fails : SendFixture -> Script ()
when_zero_amount_proposal_creation_fails f = do
  preapprovalCid <- createReceiverPreapproval f.parties f.result
  now <- getTime
  submitMustFail f.parties.member1 $ createCmd TransferProposal with
    governanceParty = f.parties.governanceParty
    proposer = f.parties.member1
    transferFactoryCid = coerceContractId preapprovalCid
    expectedAdmin = f.parties.registrar
    transfer = buildTestTransfer f.parties (testInstrumentId f.parties.registrar) now 0.0 []
    extraArgs = ExtraArgs with
      context = createTransferContext f.result
      meta = emptyMetadata

when_insufficient_confirmations_fails : SendFixture -> Script ()
when_insufficient_confirmations_fails f = do
  preapprovalCid <- createReceiverPreapproval f.parties f.result
  now <- getTime
  proposalCid <- submit f.parties.member1 $ createCmd TransferProposal with
    governanceParty = f.parties.governanceParty
    proposer = f.parties.member1
    transferFactoryCid = coerceContractId preapprovalCid
    expectedAdmin = f.parties.registrar
    transfer = buildTestTransfer f.parties (testInstrumentId f.parties.registrar) now 50.0 []
    extraArgs = ExtraArgs with
      context = createTransferContext f.result
      meta = emptyMetadata
  let proposalInterfaceCid : ContractId GovernableAction = toInterfaceContractId proposalCid
  confirmationCids <- submitConfirmations f.parties.governanceParty f.rulesCid proposalInterfaceCid
    [f.parties.member1]
  submitMustFail (memberContext f.parties.member1 f.parties.governanceParty) $
    exerciseCmd f.rulesCid GovernanceRules_ExecuteConfirmedAction with
      executor = f.parties.member1
      actionProposalCid = proposalInterfaceCid
      confirmations = confirmationCids

when_non_member_confirmation_fails : SendFixture -> Script ()
when_non_member_confirmation_fails f = do
  preapprovalCid <- createReceiverPreapproval f.parties f.result
  now <- getTime
  proposalCid <- submit f.parties.member1 $ createCmd TransferProposal with
    governanceParty = f.parties.governanceParty
    proposer = f.parties.member1
    transferFactoryCid = coerceContractId preapprovalCid
    expectedAdmin = f.parties.registrar
    transfer = buildTestTransfer f.parties (testInstrumentId f.parties.registrar) now 50.0 []
    extraArgs = ExtraArgs with
      context = createTransferContext f.result
      meta = emptyMetadata
  let proposalInterfaceCid : ContractId GovernableAction = toInterfaceContractId proposalCid
  submitMustFail (memberContext f.parties.outsider f.parties.governanceParty) $
    exerciseCmd f.rulesCid GovernanceRules_ConfirmAction with
      confirmer = f.parties.outsider
      actionProposalCid = proposalInterfaceCid

when_tokens_sent_via_governance : SendFixture -> Script [ContractId Holding]
when_tokens_sent_via_governance f = do
  let instrument = testInstrumentId f.parties.registrar
  holdingCids <- mintTokens f.parties.governanceParty 100.0 f.result (Some "Test Mint")
  preapprovalCid <- createReceiverPreapproval f.parties f.result
  now <- getTime
  proposalCid <- submit f.parties.member1 $ createCmd TransferProposal with
    governanceParty = f.parties.governanceParty
    proposer = f.parties.member1
    transferFactoryCid = coerceContractId preapprovalCid
    expectedAdmin = f.parties.registrar
    transfer = buildTestTransfer f.parties instrument now 50.0 holdingCids
    extraArgs = ExtraArgs with
      context = createTransferContext f.result
      meta = emptyMetadata
  let proposalInterfaceCid : ContractId GovernableAction = toInterfaceContractId proposalCid
  confirmAndExecute f.parties f.rulesCid proposalInterfaceCid
    [f.parties.member1, f.parties.member2] f.parties.member1
  results <- queryInterface @Holding f.parties.outsider
  pure (map fst results)

-- ============================================================================
-- Then
-- ============================================================================

then_nothing_to_verify : SendFixture -> () -> Script Failures
then_nothing_to_verify _ _ = pure []

then_outsider_received_holdings : SendFixture -> [ContractId Holding] -> Script Failures
then_outsider_received_holdings _ holdings =
  pure $ shouldNotBeEmpty "outsider holdings" holdings

-- ============================================================================
-- Tests
-- ============================================================================

testSendTokensZeroAmountRejected = script do
  run Test with
    given = given_governance_with_token_setup
    when = when_zero_amount_proposal_creation_fails
    then_ = then_nothing_to_verify

testSendTokensInsufficientConfirmations = script do
  run Test with
    given = given_governance_with_token_setup
    when = when_insufficient_confirmations_fails
    then_ = then_nothing_to_verify

testSendTokensNonMemberCannotConfirm = script do
  run Test with
    given = given_governance_with_token_setup
    when = when_non_member_confirmation_fails
    then_ = then_nothing_to_verify

testSendTokensGovernanceHappyPath = script do
  run Test with
    given = given_governance_with_token_setup
    when = when_tokens_sent_via_governance
    then_ = then_outsider_received_holdings
