-- | Tests for the SetupTokenPreapprovalProposal governable action.
module Governance.TokenCustody.Test.SetupTokenPreapprovalTest where

import DA.List (head)
import DA.Time (addRelTime, hours)
import Daml.Script

import Splice.Api.Token.HoldingV1 (Holding)
import Splice.Api.Token.MetadataV1 (ExtraArgs(..), emptyMetadata)
import Splice.Api.Token.TransferInstructionV1 (Transfer(..), TransferFactory, TransferFactory_Transfer(..))

import Utility.Registry.App.V0.Model.TransferPreapproval (InstrumentAllowance(..), TransferPreapproval(..))

import Governance.Action (GovernableAction)
import Governance.Rules (GovernanceRules(..), GovernanceRules_ConfirmAction(..))
import Governance.TokenCustody.SetupTokenPreapproval
import Governance.TokenCustody.TestUtils

import TestHarness
import TestLib.Token (SetupTokenResult(..))
import TestLib.TokenOps (mintTokens, createTransferContext)

-- ============================================================================
-- Fixtures
-- ============================================================================

data PreapprovalFixture = PreapprovalFixture
  with
    parties : TokenTestParties
    rulesCid : ContractId GovernanceRules
  deriving (Eq, Show)

data PreapprovalWithTokenFixture = PreapprovalWithTokenFixture
  with
    parties : TokenTestParties
    result : SetupTokenResult
    rulesCid : ContractId GovernanceRules
  deriving (Eq, Show)

-- ============================================================================
-- Given
-- ============================================================================

given_governance : Script PreapprovalFixture
given_governance = do
  parties <- allocateTokenTestParties
  rulesCid <- createTestGovernance parties
  pure PreapprovalFixture with ..

given_governance_with_token_setup : Script PreapprovalWithTokenFixture
given_governance_with_token_setup = do
  parties <- allocateTokenTestParties
  result <- setupTestToken parties
  rulesCid <- createTestGovernance parties
  pure PreapprovalWithTokenFixture with ..

-- ============================================================================
-- When
-- ============================================================================

when_full_flow_executed : PreapprovalFixture -> Script ()
when_full_flow_executed f = do
  proposalCid <- submit f.parties.member1 $ createCmd SetupTokenPreapprovalProposal with
    governanceParty = f.parties.governanceParty
    proposer = f.parties.member1
    operator = f.parties.outsider
    instrumentAdmin = f.parties.registrar
    instrumentAllowances = [InstrumentAllowance with id = "TEST-TOKEN"]
  let proposalInterfaceCid : ContractId GovernableAction = toInterfaceContractId proposalCid
  confirmAndExecute f.parties f.rulesCid proposalInterfaceCid
    [f.parties.member1, f.parties.member2] f.parties.member1

when_non_member_confirmation_fails : PreapprovalFixture -> Script ()
when_non_member_confirmation_fails f = do
  proposalCid <- submit f.parties.member1 $ createCmd SetupTokenPreapprovalProposal with
    governanceParty = f.parties.governanceParty
    proposer = f.parties.member1
    operator = f.parties.outsider
    instrumentAdmin = f.parties.registrar
    instrumentAllowances = []
  let proposalInterfaceCid : ContractId GovernableAction = toInterfaceContractId proposalCid
  submitMustFail (memberContext f.parties.outsider f.parties.governanceParty) $
    exerciseCmd f.rulesCid GovernanceRules_ConfirmAction with
      confirmer = f.parties.outsider
      actionProposalCid = proposalInterfaceCid

when_all_instruments_flow_executed : PreapprovalFixture -> Script ()
when_all_instruments_flow_executed f = do
  proposalCid <- submit f.parties.member1 $ createCmd SetupTokenPreapprovalProposal with
    governanceParty = f.parties.governanceParty
    proposer = f.parties.member1
    operator = f.parties.outsider
    instrumentAdmin = f.parties.registrar
    instrumentAllowances = []
  let proposalInterfaceCid : ContractId GovernableAction = toInterfaceContractId proposalCid
  confirmAndExecute f.parties f.rulesCid proposalInterfaceCid
    [f.parties.member2, f.parties.member3] f.parties.member3

when_e2e_tokens_received : PreapprovalWithTokenFixture -> Script [ContractId Holding]
when_e2e_tokens_received f = do
  let instrument = testInstrumentId f.parties.registrar
  proposalCid <- submit f.parties.member1 $ createCmd SetupTokenPreapprovalProposal with
    governanceParty = f.parties.governanceParty
    proposer = f.parties.member1
    operator = f.result.operator
    instrumentAdmin = f.parties.registrar
    instrumentAllowances = []
  let proposalInterfaceCid : ContractId GovernableAction = toInterfaceContractId proposalCid
  confirmAndExecute f.parties f.rulesCid proposalInterfaceCid
    [f.parties.member1, f.parties.member2] f.parties.member1
  [(preapprovalCid, _)] <- query @TransferPreapproval f.parties.governanceParty
  let factoryCid : ContractId TransferFactory = coerceContractId preapprovalCid
  holdingCids <- mintTokens f.parties.outsider 100.0 f.result (Some "Test Mint")
  now <- getTime
  submit (actAs f.parties.outsider
    <> readAs f.parties.registrar <> readAs f.parties.operator <> readAs f.parties.dso) $
    exerciseCmd factoryCid TransferFactory_Transfer with
      expectedAdmin = f.parties.registrar
      transfer = Transfer with
        sender = f.parties.outsider
        receiver = f.parties.governanceParty
        amount = 50.0
        instrumentId = instrument
        requestedAt = now
        executeBefore = now `addRelTime` hours 24
        inputHoldingCids = holdingCids
        meta = emptyMetadata
      extraArgs = ExtraArgs with
        context = createTransferContext f.result
        meta = emptyMetadata
  results <- queryInterface @Holding f.parties.governanceParty
  pure (map fst results)

-- ============================================================================
-- Then
-- ============================================================================

then_preapproval_created : PreapprovalFixture -> () -> Script Failures
then_preapproval_created f _ = do
  preapprovals <- query @TransferPreapproval f.parties.governanceParty
  let (_, preapproval) = head preapprovals
  pure $
    shouldBe "TransferPreapproval count" 1 (length preapprovals) <>
    shouldBe "Receiver" f.parties.governanceParty preapproval.receiver <>
    shouldBe "Operator" f.parties.outsider preapproval.operator <>
    shouldBe "InstrumentAdmin" f.parties.registrar preapproval.instrumentAdmin <>
    shouldBe "InstrumentAllowances count" 1 (length preapproval.instrumentAllowances)

then_nothing_to_verify : PreapprovalFixture -> () -> Script Failures
then_nothing_to_verify _ _ = pure []

then_all_instruments_preapproval_created : PreapprovalFixture -> () -> Script Failures
then_all_instruments_preapproval_created f _ = do
  preapprovals <- query @TransferPreapproval f.parties.governanceParty
  let (_, preapproval) = head preapprovals
  pure $
    shouldBe "TransferPreapproval count" 1 (length preapprovals) <>
    shouldBe "InstrumentAllowances" [] preapproval.instrumentAllowances

then_gov_party_received_holdings : PreapprovalWithTokenFixture -> [ContractId Holding] -> Script Failures
then_gov_party_received_holdings _ holdings =
  pure $ shouldNotBeEmpty "governanceParty holdings" holdings

-- ============================================================================
-- Tests
-- ============================================================================

test_when_token_preapproval_proposed_then_preapproval_created = script do
  run Test with
    given = given_governance
    when = when_full_flow_executed
    then_ = then_preapproval_created

test_when_non_member_confirms_then_confirmation_rejected = script do
  run Test with
    given = given_governance
    when = when_non_member_confirmation_fails
    then_ = then_nothing_to_verify

test_when_empty_allowances_then_preapproval_created = script do
  run Test with
    given = given_governance
    when = when_all_instruments_flow_executed
    then_ = then_all_instruments_preapproval_created

test_when_preapproval_setup_then_tokens_receivable = script do
  run Test with
    given = given_governance_with_token_setup
    when = when_e2e_tokens_received
    then_ = then_gov_party_received_holdings
