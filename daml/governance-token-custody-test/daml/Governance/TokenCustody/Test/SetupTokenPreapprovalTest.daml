-- | Tests for the SetupTokenPreapprovalProposal governable action.
module Governance.TokenCustody.Test.SetupTokenPreapprovalTest where

import DA.List (head)
import DA.Time (addRelTime, hours)
import Daml.Script

import Splice.Api.Token.HoldingV1 (Holding)
import Splice.Api.Token.MetadataV1 (ExtraArgs(..), emptyMetadata)
import Splice.Api.Token.TransferInstructionV1 (Transfer(..), TransferFactory, TransferFactory_Transfer(..))

import Utility.Registry.App.V0.Model.TransferPreapproval (InstrumentAllowance(..), TransferPreapproval(..))

import Governance.Action (GovernableAction)
import Governance.Rules (GovernanceRules_ConfirmAction(..))
import Governance.TokenCustody.SetupTokenPreapproval
import Governance.TokenCustody.TestUtils

-- | Full governance flow: propose -> confirm -> execute -> verify token preapproval created.
testSetupTokenPreapprovalFullFlow : Script ()
testSetupTokenPreapprovalFullFlow = do
  parties <- allocateTokenTestParties
  rulesCid <- createTestGovernance parties

  -- Proposer creates the setup token preapproval proposal
  proposalCid <- submit parties.member1 $ createCmd SetupTokenPreapprovalProposal with
    governanceParty = parties.governanceParty
    proposer = parties.member1
    operator = parties.outsider
    instrumentAdmin = parties.registrar
    instrumentAllowances = [InstrumentAllowance with id = "TEST-TOKEN"]

  let proposalInterfaceCid : ContractId GovernableAction = toInterfaceContractId proposalCid

  -- Confirm and execute
  confirmAndExecute parties rulesCid proposalInterfaceCid
    [parties.member1, parties.member2] parties.member1

  -- Verify the TransferPreapproval was created
  preapprovals <- query @TransferPreapproval parties.governanceParty
  assertMsg "TransferPreapproval should exist" (length preapprovals == 1)
  let (_, preapproval) = head preapprovals
  assertMsg "Receiver should be governanceParty" (preapproval.receiver == parties.governanceParty)
  assertMsg "Operator should match" (preapproval.operator == parties.outsider)
  assertMsg "InstrumentAdmin should match" (preapproval.instrumentAdmin == parties.registrar)
  assertMsg "InstrumentAllowances should match" (length preapproval.instrumentAllowances == 1)

-- | Non-member cannot confirm a SetupTokenPreapproval proposal.
testSetupTokenPreapprovalNonMemberCannotConfirm : Script ()
testSetupTokenPreapprovalNonMemberCannotConfirm = do
  parties <- allocateTokenTestParties
  rulesCid <- createTestGovernance parties

  proposalCid <- submit parties.member1 $ createCmd SetupTokenPreapprovalProposal with
    governanceParty = parties.governanceParty
    proposer = parties.member1
    operator = parties.outsider
    instrumentAdmin = parties.registrar
    instrumentAllowances = []

  let proposalInterfaceCid : ContractId GovernableAction = toInterfaceContractId proposalCid

  submitMustFail (memberContext parties.outsider parties.governanceParty) $
    exerciseCmd rulesCid GovernanceRules_ConfirmAction with
      confirmer = parties.outsider
      actionProposalCid = proposalInterfaceCid

-- | Setup token preapproval with empty allowances (all instruments) works.
testSetupTokenPreapprovalAllInstruments : Script ()
testSetupTokenPreapprovalAllInstruments = do
  parties <- allocateTokenTestParties
  rulesCid <- createTestGovernance parties

  proposalCid <- submit parties.member1 $ createCmd SetupTokenPreapprovalProposal with
    governanceParty = parties.governanceParty
    proposer = parties.member1
    operator = parties.outsider
    instrumentAdmin = parties.registrar
    instrumentAllowances = []

  let proposalInterfaceCid : ContractId GovernableAction = toInterfaceContractId proposalCid

  confirmAndExecute parties rulesCid proposalInterfaceCid
    [parties.member2, parties.member3] parties.member3

  preapprovals <- query @TransferPreapproval parties.governanceParty
  assertMsg "TransferPreapproval should exist" (length preapprovals == 1)
  let (_, preapproval) = head preapprovals
  assertMsg "InstrumentAllowances should be empty" (null preapproval.instrumentAllowances)

-- | End-to-end: governance sets up token preapproval, outsider sends tokens through it.
testSetupTokenPreapprovalAndReceiveTokens : Script ()
testSetupTokenPreapprovalAndReceiveTokens = do
  parties <- allocateTokenTestParties
  let instrument = testInstrumentId parties.registrar
  onboarding <- onboardToUtility parties instrument
  rulesCid <- createTestGovernance parties

  -- 1. Governance sets up TransferPreapproval with correct utility parties
  proposalCid <- submit parties.member1 $ createCmd SetupTokenPreapprovalProposal with
    governanceParty = parties.governanceParty
    proposer = parties.member1
    operator = onboarding.operator
    instrumentAdmin = parties.registrar
    instrumentAllowances = []

  let proposalInterfaceCid : ContractId GovernableAction = toInterfaceContractId proposalCid
  confirmAndExecute parties rulesCid proposalInterfaceCid
    [parties.member1, parties.member2] parties.member1

  -- 2. Get the created TransferPreapproval
  [(preapprovalCid, _)] <- query @TransferPreapproval parties.governanceParty
  let factoryCid : ContractId TransferFactory = coerceContractId preapprovalCid

  -- 3. Mint tokens for the outsider (sender)
  holdingCids <- mintTokens parties.outsider 100.0 onboarding instrument
  now <- getTime

  -- 4. Outsider sends tokens to governance party via the preapproval
  submit (actAs parties.outsider
    <> readAs parties.registrar <> readAs parties.operator <> readAs parties.dso) $
    exerciseCmd factoryCid TransferFactory_Transfer with
      expectedAdmin = parties.registrar
      transfer = Transfer with
        sender = parties.outsider
        receiver = parties.governanceParty
        amount = 50.0
        instrumentId = instrument
        requestedAt = now
        executeBefore = now `addRelTime` hours 24
        inputHoldingCids = holdingCids
        meta = emptyMetadata
      extraArgs = ExtraArgs with
        context = createTransferContext onboarding
        meta = emptyMetadata

  -- 5. Verify governance party received tokens
  govHoldings <- queryInterface @Holding parties.governanceParty
  assertMsg "GovernanceParty should have received holdings" (not (null govHoldings))
