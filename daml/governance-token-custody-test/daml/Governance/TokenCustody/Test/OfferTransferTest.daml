-- | Tests for two-step transfers using TransferProposal with AllocationFactory.
-- When the AllocationFactory is used as the TransferFactory, it creates a pending
-- TransferOffer that the receiver must accept separately.
module Governance.TokenCustody.Test.OfferTransferTest where

import DA.Time (addRelTime, hours)
import Daml.Script

import Splice.Api.Token.HoldingV1 (Holding, InstrumentId)
import Splice.Api.Token.MetadataV1 (ExtraArgs(..), emptyMetadata)
import Splice.Api.Token.TransferInstructionV1 (Transfer(..), TransferInstruction, TransferInstruction_Accept(..))

import Utility.Registry.App.V0.Model.Transfer (TransferOffer)

import Governance.Action (GovernableAction)
import Governance.Rules (GovernanceRules(..), GovernanceRules_ConfirmAction(..), GovernanceRules_ExecuteConfirmedAction(..))
import Governance.TokenCustody.TransferProposal
import Governance.TokenCustody.TestUtils

import TestHarness (Test(..), run, Failures, shouldNotBeEmpty)
import TestLib.Token (SetupTokenResult(..))
import TestLib.TokenOps (mintTokens, createTransferContext)

-- ============================================================================
-- Fixtures
-- ============================================================================

data OfferFixture = OfferFixture
  with
    parties : TokenTestParties
    result : SetupTokenResult
    rulesCid : ContractId GovernanceRules
  deriving (Eq, Show)

-- ============================================================================
-- Helpers
-- ============================================================================

-- | Build a standard Transfer from governance party to outsider.
buildTestTransfer : TokenTestParties -> InstrumentId -> Time -> Decimal -> [ContractId Holding] -> Transfer
buildTestTransfer parties instrument now amount holdingCids = Transfer with
  sender = parties.governanceParty
  receiver = parties.outsider
  amount
  instrumentId = instrument
  requestedAt = now
  executeBefore = now `addRelTime` hours 24
  inputHoldingCids = holdingCids
  meta = emptyMetadata

-- | Helper to create a TransferProposal targeting the AllocationFactory (two-step).
createOfferProposal : TokenTestParties -> SetupTokenResult -> [ContractId Holding] -> Decimal -> Script (ContractId TransferProposal)
createOfferProposal parties result holdingCids amount = do
  let instrument = testInstrumentId parties.registrar
  now <- getTime
  submit parties.member1 $ createCmd TransferProposal with
    governanceParty = parties.governanceParty
    proposer = parties.member1
    transferFactoryCid = coerceContractId result.allocationFactoryCid
    expectedAdmin = parties.registrar
    transfer = buildTestTransfer parties instrument now amount holdingCids
    extraArgs = ExtraArgs with
      context = createTransferContext result
      meta = emptyMetadata

-- ============================================================================
-- Given
-- ============================================================================

given_governance_with_token_setup : Script OfferFixture
given_governance_with_token_setup = do
  parties <- allocateTokenTestParties
  result <- setupTestToken parties
  rulesCid <- createTestGovernance parties
  pure OfferFixture with ..

-- ============================================================================
-- When
-- ============================================================================

when_zero_amount_proposal_creation_fails : OfferFixture -> Script ()
when_zero_amount_proposal_creation_fails f = do
  now <- getTime
  submitMustFail f.parties.member1 $ createCmd TransferProposal with
    governanceParty = f.parties.governanceParty
    proposer = f.parties.member1
    transferFactoryCid = coerceContractId f.result.allocationFactoryCid
    expectedAdmin = f.parties.registrar
    transfer = buildTestTransfer f.parties (testInstrumentId f.parties.registrar) now 0.0 []
    extraArgs = ExtraArgs with
      context = createTransferContext f.result
      meta = emptyMetadata

when_insufficient_confirmations_fails : OfferFixture -> Script ()
when_insufficient_confirmations_fails f = do
  proposalCid <- createOfferProposal f.parties f.result [] 50.0
  let proposalInterfaceCid : ContractId GovernableAction = toInterfaceContractId proposalCid
  confirmationCids <- submitConfirmations f.parties.governanceParty f.rulesCid proposalInterfaceCid
    [f.parties.member1]
  submitMustFail (memberContext f.parties.member1 f.parties.governanceParty) $
    exerciseCmd f.rulesCid GovernanceRules_ExecuteConfirmedAction with
      executor = f.parties.member1
      actionProposalCid = proposalInterfaceCid
      confirmations = confirmationCids

when_non_member_confirmation_fails : OfferFixture -> Script ()
when_non_member_confirmation_fails f = do
  proposalCid <- createOfferProposal f.parties f.result [] 50.0
  let proposalInterfaceCid : ContractId GovernableAction = toInterfaceContractId proposalCid
  submitMustFail (memberContext f.parties.outsider f.parties.governanceParty) $
    exerciseCmd f.rulesCid GovernanceRules_ConfirmAction with
      confirmer = f.parties.outsider
      actionProposalCid = proposalInterfaceCid

when_transfer_offered_via_governance : OfferFixture -> Script [ContractId Holding]
when_transfer_offered_via_governance f = do
  holdingCids <- mintTokens f.parties.governanceParty 100.0 f.result (Some "Test Mint")
  proposalCid <- createOfferProposal f.parties f.result holdingCids 50.0
  let proposalInterfaceCid : ContractId GovernableAction = toInterfaceContractId proposalCid
  confirmAndExecute f.parties f.rulesCid proposalInterfaceCid
    [f.parties.member1, f.parties.member2] f.parties.member1
  [(transferOfferCid, _)] <- query @TransferOffer f.parties.outsider
  let transferInstructionCid : ContractId TransferInstruction = coerceContractId transferOfferCid
  submit (actAs f.parties.outsider <> actAs f.parties.governanceParty
    <> readAs f.parties.registrar <> readAs f.parties.operator <> readAs f.parties.dso) $
    exerciseCmd transferInstructionCid TransferInstruction_Accept with
      extraArgs = ExtraArgs with
        context = createTransferContext f.result
        meta = emptyMetadata
  results <- queryInterface @Holding f.parties.outsider
  pure (map fst results)

-- ============================================================================
-- Then
-- ============================================================================

then_nothing_to_verify : OfferFixture -> () -> Script Failures
then_nothing_to_verify _ _ = pure []

then_outsider_received_holdings : OfferFixture -> [ContractId Holding] -> Script Failures
then_outsider_received_holdings _ holdings =
  pure $ shouldNotBeEmpty "outsider holdings" holdings

-- ============================================================================
-- Tests
-- ============================================================================

test_when_zero_amount_then_proposal_rejected = script do
  run Test with
    given = given_governance_with_token_setup
    when = when_zero_amount_proposal_creation_fails
    then_ = then_nothing_to_verify

test_when_insufficient_confirmations_then_execution_rejected = script do
  run Test with
    given = given_governance_with_token_setup
    when = when_insufficient_confirmations_fails
    then_ = then_nothing_to_verify

test_when_non_member_confirms_then_confirmation_rejected = script do
  run Test with
    given = given_governance_with_token_setup
    when = when_non_member_confirmation_fails
    then_ = then_nothing_to_verify

test_when_transfer_offered_then_offer_created = script do
  run Test with
    given = given_governance_with_token_setup
    when = when_transfer_offered_via_governance
    then_ = then_outsider_received_holdings
