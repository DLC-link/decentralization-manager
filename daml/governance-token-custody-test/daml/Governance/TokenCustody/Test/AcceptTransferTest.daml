-- | Tests for the AcceptTransferProposal governable action.
module Governance.TokenCustody.Test.AcceptTransferTest where

import DA.Time (addRelTime, hours)
import Daml.Script

import Splice.Api.Token.HoldingV1 (Holding)
import Splice.Api.Token.MetadataV1 (ExtraArgs(..), emptyChoiceContext, emptyMetadata)
import Splice.Api.Token.TransferInstructionV1 (Transfer(..), TransferFactory(..), TransferFactory_Transfer(..), TransferInstruction, TransferInstruction_Withdraw(..))

import Utility.Registry.App.V0.Model.Transfer (TransferOffer)

import Governance.Action (GovernableAction)
import Governance.Rules (GovernanceRules(..), GovernanceRules_ConfirmAction(..), GovernanceRules_ExecuteConfirmedAction(..))
import Governance.TokenCustody.AcceptTransfer
import Governance.TokenCustody.TestUtils

import TestHarness
import TestLib.Token (SetupTokenResult(..))
import TestLib.TokenOps (mintTokens, createTransferContext)

-- ============================================================================
-- Fixtures
-- ============================================================================

data AcceptFixture = AcceptFixture
  with
    parties : TokenTestParties
    result : SetupTokenResult
    rulesCid : ContractId GovernanceRules
  deriving (Eq, Show)

-- ============================================================================
-- Helpers
-- ============================================================================

-- | Build ExtraArgs for accept operations.
buildAcceptExtraArgs : SetupTokenResult -> ExtraArgs
buildAcceptExtraArgs result = ExtraArgs with
  context = createTransferContext result
  meta = emptyMetadata

-- | Create a pending TransferOffer from outsider to governance party.
-- Uses the AllocationFactory (TransferFactory interface) which creates a TransferOffer
-- when the sender != receiver (two-step transfer).
createTransferOffer : TokenTestParties -> SetupTokenResult -> Decimal -> Script (ContractId TransferInstruction)
createTransferOffer parties result amount = do
  now <- getTime
  let instrument = testInstrumentId parties.registrar

  -- Mint tokens for the outsider (sender)
  holdingCids <- mintTokens parties.outsider amount result (Some "Test Mint")

  -- Use AllocationFactory as TransferFactory to create a pending TransferOffer
  let factoryCid : ContractId TransferFactory = coerceContractId result.allocationFactoryCid
  submit (actAs parties.outsider <> actAs parties.registrar
    <> readAs parties.operator <> readAs parties.dso) $
    exerciseCmd factoryCid TransferFactory_Transfer with
      expectedAdmin = parties.registrar
      transfer = Transfer with
        sender = parties.outsider
        receiver = parties.governanceParty
        instrumentId = instrument
        amount
        requestedAt = now
        executeBefore = now `addRelTime` hours 24
        inputHoldingCids = holdingCids
        meta = emptyMetadata
      extraArgs = ExtraArgs with
        context = createTransferContext result
        meta = emptyMetadata

  -- The result contains a pending TransferInstruction (TransferOffer)
  -- Query it from the receiver's perspective
  [(offerCid, _)] <- query @TransferOffer parties.governanceParty
  pure (coerceContractId offerCid)

-- ============================================================================
-- Given
-- ============================================================================

given_governance_with_token_setup : Script AcceptFixture
given_governance_with_token_setup = do
  parties <- allocateTokenTestParties
  result <- setupTestToken parties
  rulesCid <- createTestGovernance parties
  pure AcceptFixture with ..

-- ============================================================================
-- When
-- ============================================================================

when_transfer_accepted_via_governance : AcceptFixture -> Script [ContractId Holding]
when_transfer_accepted_via_governance f = do
  transferInstructionCid <- createTransferOffer f.parties f.result 75.0
  proposalCid <- submit f.parties.member1 $ createCmd AcceptTransferProposal with
    governanceParty = f.parties.governanceParty
    proposer = f.parties.member1
    transferInstructionCid
    extraArgs = buildAcceptExtraArgs f.result
  let proposalInterfaceCid : ContractId GovernableAction = toInterfaceContractId proposalCid
  confirmAndExecute f.parties f.rulesCid proposalInterfaceCid
    [f.parties.member1, f.parties.member2] f.parties.member1
  results <- queryInterface @Holding f.parties.governanceParty
  pure (map fst results)

when_withdrawn_offer_fails : AcceptFixture -> Script ()
when_withdrawn_offer_fails f = do
  transferInstructionCid <- createTransferOffer f.parties f.result 75.0
  proposalCid <- submit f.parties.member1 $ createCmd AcceptTransferProposal with
    governanceParty = f.parties.governanceParty
    proposer = f.parties.member1
    transferInstructionCid
    extraArgs = buildAcceptExtraArgs f.result
  let proposalInterfaceCid : ContractId GovernableAction = toInterfaceContractId proposalCid
  -- Sender withdraws the transfer instruction before governance approves
  submit (actAs f.parties.outsider <> readAs f.parties.registrar <> readAs f.result.operator) $
    exerciseCmd transferInstructionCid TransferInstruction_Withdraw with
      extraArgs = ExtraArgs with
        context = emptyChoiceContext
        meta = emptyMetadata
  confirmationCids <- submitConfirmations f.parties.governanceParty f.rulesCid proposalInterfaceCid
    [f.parties.member1, f.parties.member2]
  submitMustFail (memberContext f.parties.member1 f.parties.governanceParty) $
    exerciseCmd f.rulesCid GovernanceRules_ExecuteConfirmedAction with
      executor = f.parties.member1
      actionProposalCid = proposalInterfaceCid
      confirmations = confirmationCids

when_non_member_confirms : AcceptFixture -> Script ()
when_non_member_confirms f = do
  transferInstructionCid <- createTransferOffer f.parties f.result 75.0
  proposalCid <- submit f.parties.member1 $ createCmd AcceptTransferProposal with
    governanceParty = f.parties.governanceParty
    proposer = f.parties.member1
    transferInstructionCid
    extraArgs = buildAcceptExtraArgs f.result
  let proposalInterfaceCid : ContractId GovernableAction = toInterfaceContractId proposalCid
  submitMustFail (memberContext f.parties.outsider f.parties.governanceParty) $
    exerciseCmd f.rulesCid GovernanceRules_ConfirmAction with
      confirmer = f.parties.outsider
      actionProposalCid = proposalInterfaceCid

-- ============================================================================
-- Then
-- ============================================================================

then_submit_failed : AcceptFixture -> () -> Script Failures
then_submit_failed _ _ = pure []

then_governance_party_received_holdings : AcceptFixture -> [ContractId Holding] -> Script Failures
then_governance_party_received_holdings _ holdings =
  pure $ shouldNotBeEmpty "governanceParty holdings" holdings

-- ============================================================================
-- Tests
-- ============================================================================

testAcceptTransferGovernanceHappyPath = script do
  run Test with
    given = given_governance_with_token_setup
    when = when_transfer_accepted_via_governance
    then_ = then_governance_party_received_holdings

testAcceptTransferWithdrawnOffer = script do
  run Test with
    given = given_governance_with_token_setup
    when = when_withdrawn_offer_fails
    then_ = then_submit_failed

testAcceptTransferNonMemberCannotConfirm = script do
  run Test with
    given = given_governance_with_token_setup
    when = when_non_member_confirms
    then_ = then_submit_failed
