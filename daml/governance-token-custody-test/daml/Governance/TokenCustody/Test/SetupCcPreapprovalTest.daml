-- | Tests for the SetupCcPreapprovalProposal governable action.
module Governance.TokenCustody.Test.SetupCcPreapprovalTest where

import Daml.Script

import Splice.Wallet.TransferPreapproval (TransferPreapprovalProposal(..))

import Governance.Action (GovernableAction)
import Governance.Rules (GovernanceRules(..), GovernanceRules_ConfirmAction(..))
import Governance.TokenCustody.SetupCcPreapproval
import Governance.TokenCustody.TestUtils

import TestHarness

-- ============================================================================
-- Fixtures
-- ============================================================================

data SetupCcFixture = SetupCcFixture
  with
    parties : TokenTestParties
    rulesCid : ContractId GovernanceRules
  deriving (Eq, Show)

-- ============================================================================
-- Given
-- ============================================================================

given_governance_setup : Script SetupCcFixture
given_governance_setup = do
  parties <- allocateTokenTestParties
  rulesCid <- createTestGovernance parties
  pure SetupCcFixture with ..

-- ============================================================================
-- When
-- ============================================================================

when_full_flow_with_dso : SetupCcFixture -> Script [TransferPreapprovalProposal]
when_full_flow_with_dso f = do
  proposalCid <- submit f.parties.member1 $ createCmd SetupCcPreapprovalProposal with
    governanceParty = f.parties.governanceParty
    governanceId = testGovernanceId
    proposer = f.parties.member1
    provider = f.parties.outsider
    expectedDso = Some f.parties.dso

  let proposalInterfaceCid : ContractId GovernableAction = toInterfaceContractId proposalCid

  confirmAndExecute f.parties f.rulesCid proposalInterfaceCid
    [f.parties.member1, f.parties.member2] f.parties.member1

  results <- query @TransferPreapprovalProposal f.parties.governanceParty
  pure (map snd results)

when_non_member_confirmation_fails : SetupCcFixture -> Script ()
when_non_member_confirmation_fails f = do
  proposalCid <- submit f.parties.member1 $ createCmd SetupCcPreapprovalProposal with
    governanceParty = f.parties.governanceParty
    governanceId = testGovernanceId
    proposer = f.parties.member1
    provider = f.parties.outsider
    expectedDso = None

  let proposalInterfaceCid : ContractId GovernableAction = toInterfaceContractId proposalCid

  submitMustFail (memberContext f.parties.outsider f.parties.governanceParty) $
    exerciseCmd f.rulesCid GovernanceRules_ConfirmAction with
      confirmer = f.parties.outsider
      actionProposalCid = proposalInterfaceCid

when_full_flow_without_dso : SetupCcFixture -> Script [TransferPreapprovalProposal]
when_full_flow_without_dso f = do
  proposalCid <- submit f.parties.member1 $ createCmd SetupCcPreapprovalProposal with
    governanceParty = f.parties.governanceParty
    governanceId = testGovernanceId
    proposer = f.parties.member1
    provider = f.parties.outsider
    expectedDso = None

  let proposalInterfaceCid : ContractId GovernableAction = toInterfaceContractId proposalCid

  confirmAndExecute f.parties f.rulesCid proposalInterfaceCid
    [f.parties.member2, f.parties.member3] f.parties.member3

  results <- query @TransferPreapprovalProposal f.parties.governanceParty
  pure (map snd results)

-- ============================================================================
-- Then
-- ============================================================================

then_nothing_to_verify : SetupCcFixture -> () -> Script Failures
then_nothing_to_verify _ _ = pure []

then_preapproval_proposal_created_with_dso : SetupCcFixture -> [TransferPreapprovalProposal] -> Script Failures
then_preapproval_proposal_created_with_dso f proposals = do
  let countCheck = shouldBe "number of TransferPreapprovalProposals" 1 (length proposals)
  case proposals of
    [] -> pure countCheck
    (proposal :: _) -> pure $
      countCheck <>
      shouldBe "receiver" f.parties.governanceParty proposal.receiver <>
      shouldBe "provider" f.parties.outsider proposal.provider <>
      shouldBe "expectedDso" (Some f.parties.dso) proposal.expectedDso

then_preapproval_proposal_created_without_dso : SetupCcFixture -> [TransferPreapprovalProposal] -> Script Failures
then_preapproval_proposal_created_without_dso _ proposals = do
  let countCheck = shouldBe "number of TransferPreapprovalProposals" 1 (length proposals)
  case proposals of
    [] -> pure countCheck
    (proposal :: _) -> pure $
      countCheck <>
      shouldBe "expectedDso" (None : Optional Party) proposal.expectedDso

-- ============================================================================
-- Tests
-- ============================================================================

test_when_cc_preapproval_proposed_then_proposal_created = script do
  run Test with
    given = given_governance_setup
    when = when_full_flow_with_dso
    then_ = then_preapproval_proposal_created_with_dso

test_when_non_member_confirms_then_confirmation_rejected = script do
  run Test with
    given = given_governance_setup
    when = when_non_member_confirmation_fails
    then_ = then_nothing_to_verify

test_when_no_dso_then_preapproval_created = script do
  run Test with
    given = given_governance_setup
    when = when_full_flow_without_dso
    then_ = then_preapproval_proposal_created_without_dso
