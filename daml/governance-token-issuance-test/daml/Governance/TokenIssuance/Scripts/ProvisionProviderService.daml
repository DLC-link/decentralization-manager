-- | Provisions a Utility-Registry `ProviderService` for a pre-allocated
-- governance party + operator pair, and returns the created contract id.
--
-- Called from the E2E integration-test harness (governance-token-issuance.sh)
-- to produce the ProviderService cid that `SetupIssuanceProposal` consumes.
-- Analogous to `initUtilityPrereqs` in TestUtils, but takes already-allocated
-- parties as input (via --input-file) instead of allocating fresh test parties.
--
-- Run via:
--   dpm script --dar <test.dar> \
--     --script-name Governance.TokenIssuance.Scripts.ProvisionProviderService:provision \
--     --ledger-host ... --ledger-port ... --access-token-file <jwt> \
--     --input-file <input.json> --output-file <output.json> \
--     --upload-dar yes --wall-clock-time
module Governance.TokenIssuance.Scripts.ProvisionProviderService where

import Daml.Script

import Utility.Registry.App.V0.Service.Provider (ProviderService(..))

data Input = Input
  with
    governanceParty : Party
    operator : Party
  deriving (Show, Eq)

data Output = Output
  with
    providerServiceCid : ContractId ProviderService
  deriving (Show, Eq)

provision : Input -> Script Output
provision i = do
  cid <- submit (actAs i.governanceParty <> actAs i.operator) $
    createCmd ProviderService with
      operator = i.operator
      provider = i.governanceParty
  pure Output with providerServiceCid = cid
