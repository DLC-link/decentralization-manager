flowchart TD
    Start([Start]) --> ChooseWorkflow{Choose Workflow}

    ChooseWorkflow -->|onboarding| OnboardingStart[Onboarding Workflow:<br/>Create Decentralized Party]
    ChooseWorkflow -->|contracts| ContractsStart[Contracts Workflow:<br/>Deploy Governance Contracts]
    ChooseWorkflow -->|kick| KickStart[Kick Workflow:<br/>Remove Participant]

    %% ==================== ONBOARDING WORKFLOW ====================

    OnboardingStart --> OB_NoiseSetup[Noise Protocol: Peer Discovery & Handshake]

    OB_NoiseSetup --> OB_Connect1[Coordinator establishes<br/>Noise channel with Attestor 1]
    OB_NoiseSetup --> OB_Connect2[Coordinator establishes<br/>Noise channel with Attestor 2]
    OB_NoiseSetup --> OB_ConnectN[Coordinator establishes<br/>Noise channel with Attestor N]

    OB_Connect1 --> OB_AuthPeers{All Peers<br/>Authenticated?}
    OB_Connect2 --> OB_AuthPeers
    OB_ConnectN --> OB_AuthPeers

    OB_AuthPeers -->|Yes| OB_Phase1[Phase 1: Key Generation]
    OB_AuthPeers -->|No| OB_NoiseSetup

    %% Phase 1: Generate Keys
    OB_Phase1 --> OB_Cmd1[Coordinator broadcasts via Noise:<br/>COMMAND: GenerateKeys]

    OB_Cmd1 --> OB_GenKeys1[Attestor 1: Generate Keys<br/>namespace + DAML keys]
    OB_Cmd1 --> OB_GenKeys2[Attestor 2: Generate Keys<br/>namespace + DAML keys]
    OB_Cmd1 --> OB_GenKeysN[Attestor N: Generate Keys<br/>namespace + DAML keys]

    OB_GenKeys1 --> OB_SendKeys1[Attestor 1 sends via Noise:<br/>attestor-public-keys.bin<br/>participant-id.bin]
    OB_GenKeys2 --> OB_SendKeys2[Attestor 2 sends via Noise:<br/>attestor-public-keys.bin<br/>participant-id.bin]
    OB_GenKeysN --> OB_SendKeysN[Attestor N sends via Noise:<br/>attestor-public-keys.bin<br/>participant-id.bin]

    OB_SendKeys1 --> OB_CollectKeys{Coordinator receives<br/>all keys via Noise}
    OB_SendKeys2 --> OB_CollectKeys
    OB_SendKeysN --> OB_CollectKeys

    %% Phase 2: Create Proposals (Coordinator only)
    OB_CollectKeys --> OB_Phase2[Phase 2: Proposal Creation]
    OB_Phase2 --> OB_CreateProposals[Coordinator: Create Proposals<br/>DNS + P2P proposals<br/>Canton 3.4+: keys embedded in P2P]

    %% Phase 3: Sign DNS
    OB_CreateProposals --> OB_Phase3[Phase 3: DNS Signing]
    OB_Phase3 --> OB_DistDns[Coordinator distributes via Noise:<br/>dns_proto.bin to all attestors]

    OB_DistDns --> OB_SignDns1[Attestor 1: Sign DNS Proposal]
    OB_DistDns --> OB_SignDns2[Attestor 2: Sign DNS Proposal]
    OB_DistDns --> OB_SignDnsN[Attestor N: Sign DNS Proposal]

    OB_SignDns1 --> OB_SendDns1[Attestor 1 sends via Noise:<br/>signed-dns-proposal.bin]
    OB_SignDns2 --> OB_SendDns2[Attestor 2 sends via Noise:<br/>signed-dns-proposal.bin]
    OB_SignDnsN --> OB_SendDnsN[Attestor N sends via Noise:<br/>signed-dns-proposal.bin]

    OB_SendDns1 --> OB_CollectDns{Coordinator receives<br/>all DNS signatures}
    OB_SendDns2 --> OB_CollectDns
    OB_SendDnsN --> OB_CollectDns

    %% Submit DNS (Coordinator only)
    OB_CollectDns --> OB_SubmitDns[Coordinator: Submit DNS Proposal<br/>Aggregate & submit to Canton]

    %% Phase 4: Sign P2P
    OB_SubmitDns --> OB_Phase4[Phase 4: P2P Signing]
    OB_Phase4 --> OB_DistP2p[Coordinator distributes via Noise:<br/>p2p_proto.bin to all attestors]

    OB_DistP2p --> OB_SignP2p1[Attestor 1: Sign P2P Proposals]
    OB_DistP2p --> OB_SignP2p2[Attestor 2: Sign P2P Proposals]
    OB_DistP2p --> OB_SignP2pN[Attestor N: Sign P2P Proposals]

    OB_SignP2p1 --> OB_SendP2p1[Attestor 1 sends via Noise:<br/>signed-p2p-proposals.bin]
    OB_SignP2p2 --> OB_SendP2p2[Attestor 2 sends via Noise:<br/>signed-p2p-proposals.bin]
    OB_SignP2pN --> OB_SendP2pN[Attestor N sends via Noise:<br/>signed-p2p-proposals.bin]

    OB_SendP2p1 --> OB_CollectP2p{Coordinator receives<br/>all P2P signatures}
    OB_SendP2p2 --> OB_CollectP2p
    OB_SendP2pN --> OB_CollectP2p

    %% Submit Final (Coordinator only)
    OB_CollectP2p --> OB_SubmitFinal[Coordinator: Submit Final Proposals<br/>Aggregate & submit P2P to Canton]

    OB_SubmitFinal --> OB_Disconnect[Coordinator broadcasts:<br/>DISCONNECT]
    OB_Disconnect --> OB_Complete([Onboarding Complete:<br/>Decentralized Party Created])

    %% ==================== CONTRACTS WORKFLOW ====================

    ContractsStart --> CT_NoiseSetup[Noise Protocol: Peer Discovery & Handshake]

    CT_NoiseSetup --> CT_Connect1[Coordinator establishes<br/>Noise channel with Attestor 1]
    CT_NoiseSetup --> CT_Connect2[Coordinator establishes<br/>Noise channel with Attestor 2]
    CT_NoiseSetup --> CT_ConnectN[Coordinator establishes<br/>Noise channel with Attestor N]

    CT_Connect1 --> CT_AuthPeers{All Peers<br/>Authenticated?}
    CT_Connect2 --> CT_AuthPeers
    CT_ConnectN --> CT_AuthPeers

    CT_AuthPeers -->|Yes| CT_Phase1[Phase 1: DAR Upload]
    CT_AuthPeers -->|No| CT_NoiseSetup

    %% Phase 1: Upload DARs
    CT_Phase1 --> CT_Cmd1[Coordinator broadcasts via Noise:<br/>COMMAND: UploadDars]

    CT_Cmd1 --> CT_Upload1[Attestor 1: Upload DARs<br/>from dars/ directory]
    CT_Cmd1 --> CT_Upload2[Attestor 2: Upload DARs<br/>from dars/ directory]
    CT_Cmd1 --> CT_UploadN[Attestor N: Upload DARs<br/>from dars/ directory]

    CT_Upload1 --> CT_Ack1[Attestor 1 sends via Noise:<br/>ACK]
    CT_Upload2 --> CT_Ack2[Attestor 2 sends via Noise:<br/>ACK]
    CT_UploadN --> CT_AckN[Attestor N sends via Noise:<br/>ACK]

    CT_Ack1 --> CT_CollectAcks{Coordinator receives<br/>all ACKs}
    CT_Ack2 --> CT_CollectAcks
    CT_AckN --> CT_CollectAcks

    %% Phase 2: Prepare Submissions (Coordinator only)
    CT_CollectAcks --> CT_Phase2[Phase 2: Submission Preparation]
    CT_Phase2 --> CT_PrepareSubmissions[Coordinator: Prepare Submissions<br/>Allocate parties & create users<br/>Build contract commands]

    %% Phase 3: Sign Submissions
    CT_PrepareSubmissions --> CT_Phase3[Phase 3: Submission Signing]
    CT_Phase3 --> CT_DistSub[Coordinator distributes via Noise:<br/>prepared-submission-*.bin]

    CT_DistSub --> CT_SignSub1[Attestor 1: Sign Submissions]
    CT_DistSub --> CT_SignSub2[Attestor 2: Sign Submissions]
    CT_DistSub --> CT_SignSubN[Attestor N: Sign Submissions]

    CT_SignSub1 --> CT_SendSig1[Attestor 1 sends via Noise:<br/>submission-signatures.bin]
    CT_SignSub2 --> CT_SendSig2[Attestor 2 sends via Noise:<br/>submission-signatures.bin]
    CT_SignSubN --> CT_SendSigN[Attestor N sends via Noise:<br/>submission-signatures.bin]

    CT_SendSig1 --> CT_CollectSigs{Coordinator receives<br/>all signatures}
    CT_SendSig2 --> CT_CollectSigs
    CT_SendSigN --> CT_CollectSigs

    %% Phase 4: Execute Submissions (Coordinator only)
    CT_CollectSigs --> CT_Phase4[Phase 4: Execution]
    CT_Phase4 --> CT_Execute[Coordinator: Execute Submissions<br/>Aggregate signatures & submit<br/>to Ledger API]

    CT_Execute --> CT_Disconnect[Coordinator broadcasts:<br/>DISCONNECT]
    CT_Disconnect --> CT_Complete([Contracts Complete:<br/>Governance Contracts Deployed])

    %% ==================== KICK WORKFLOW ====================

    KickStart --> KK_NoiseSetup[Noise Protocol: Peer Discovery & Handshake]

    KK_NoiseSetup --> KK_Connect1[Coordinator establishes<br/>Noise channel with Attestor 1]
    KK_NoiseSetup --> KK_Connect2[Coordinator establishes<br/>Noise channel with Attestor N]
    KK_NoiseSetup --> KK_Note[Note: Kicked participant<br/>does NOT connect]

    KK_Connect1 --> KK_AuthPeers{All Remaining Peers<br/>Authenticated?}
    KK_Connect2 --> KK_AuthPeers

    KK_AuthPeers -->|Yes| KK_Phase1[Phase 1: Export State]
    KK_AuthPeers -->|No| KK_NoiseSetup

    %% Phase 1: Export State (Coordinator only)
    KK_Phase1 --> KK_ExportState[Coordinator: Export State<br/>Query namespace & P2P<br/>Verify participant to kick<br/>Calculate new threshold]

    %% Phase 2: Create Kick Proposals (Coordinator only)
    KK_ExportState --> KK_Phase2[Phase 2: Proposal Creation]
    KK_Phase2 --> KK_CreateProposals[Coordinator: Create Kick Proposals<br/>Updated DNS removed owner<br/>Updated P2P removed participant]

    %% Phase 3: Sign Kick Proposals
    KK_CreateProposals --> KK_Phase3[Phase 3: Kick Signing]
    KK_Phase3 --> KK_DistKick[Coordinator distributes via Noise:<br/>kick_dns_proto.bin<br/>kick_p2p_proto.bin]

    KK_DistKick --> KK_SignKick1[Attestor 1: Sign Kick Proposals]
    KK_DistKick --> KK_SignKickN[Attestor N: Sign Kick Proposals]

    KK_SignKick1 --> KK_SendKick1[Attestor 1 sends via Noise:<br/>signed-kick-proposals.bin]
    KK_SignKickN --> KK_SendKickN[Attestor N sends via Noise:<br/>signed-kick-proposals.bin]

    KK_SendKick1 --> KK_CollectKick{Coordinator receives<br/>all kick signatures}
    KK_SendKickN --> KK_CollectKick

    %% Submit Kick (Coordinator only)
    KK_CollectKick --> KK_SubmitKick[Coordinator: Submit Kick Proposals<br/>Aggregate & submit to Canton]

    KK_SubmitKick --> KK_Disconnect[Coordinator broadcasts:<br/>DISCONNECT]
    KK_Disconnect --> KK_Complete([Kick Complete:<br/>Participant Removed])

    %% ==================== STYLING ====================

    %% Noise Protocol nodes (red)
    style OB_NoiseSetup fill:#ff9999,stroke:#cc0000,stroke-width:3px,color:#000
    style OB_Connect1 fill:#ffcccc,color:#000
    style OB_Connect2 fill:#ffcccc,color:#000
    style OB_ConnectN fill:#ffcccc,color:#000
    style OB_AuthPeers fill:#ff9999,color:#000
    style OB_Disconnect fill:#ff9999,stroke:#cc0000,stroke-width:3px,color:#000

    style CT_NoiseSetup fill:#ff9999,stroke:#cc0000,stroke-width:3px,color:#000
    style CT_Connect1 fill:#ffcccc,color:#000
    style CT_Connect2 fill:#ffcccc,color:#000
    style CT_ConnectN fill:#ffcccc,color:#000
    style CT_AuthPeers fill:#ff9999,color:#000
    style CT_Disconnect fill:#ff9999,stroke:#cc0000,stroke-width:3px,color:#000

    %% Coordinator commands/distributions (blue)
    style OB_Cmd1 fill:#99ccff,stroke:#0066cc,stroke-width:2px,color:#000
    style OB_DistDns fill:#99ccff,stroke:#0066cc,stroke-width:2px,color:#000
    style OB_DistP2p fill:#99ccff,stroke:#0066cc,stroke-width:2px,color:#000

    style CT_Cmd1 fill:#99ccff,stroke:#0066cc,stroke-width:2px,color:#000
    style CT_DistSub fill:#99ccff,stroke:#0066cc,stroke-width:2px,color:#000

    %% Attestor responses (green)
    style OB_SendKeys1 fill:#ccffcc,stroke:#009900,stroke-width:2px,color:#000
    style OB_SendKeys2 fill:#ccffcc,stroke:#009900,stroke-width:2px,color:#000
    style OB_SendKeysN fill:#ccffcc,stroke:#009900,stroke-width:2px,color:#000
    style OB_SendDns1 fill:#ccffcc,stroke:#009900,stroke-width:2px,color:#000
    style OB_SendDns2 fill:#ccffcc,stroke:#009900,stroke-width:2px,color:#000
    style OB_SendDnsN fill:#ccffcc,stroke:#009900,stroke-width:2px,color:#000
    style OB_SendP2p1 fill:#ccffcc,stroke:#009900,stroke-width:2px,color:#000
    style OB_SendP2p2 fill:#ccffcc,stroke:#009900,stroke-width:2px,color:#000
    style OB_SendP2pN fill:#ccffcc,stroke:#009900,stroke-width:2px,color:#000

    style CT_Ack1 fill:#ccffcc,stroke:#009900,stroke-width:2px,color:#000
    style CT_Ack2 fill:#ccffcc,stroke:#009900,stroke-width:2px,color:#000
    style CT_AckN fill:#ccffcc,stroke:#009900,stroke-width:2px,color:#000
    style CT_SendSig1 fill:#ccffcc,stroke:#009900,stroke-width:2px,color:#000
    style CT_SendSig2 fill:#ccffcc,stroke:#009900,stroke-width:2px,color:#000
    style CT_SendSigN fill:#ccffcc,stroke:#009900,stroke-width:2px,color:#000

    %% Attestor operations (light blue)
    style OB_GenKeys1 fill:#e1f5ff,color:#000
    style OB_GenKeys2 fill:#e1f5ff,color:#000
    style OB_GenKeysN fill:#e1f5ff,color:#000
    style OB_SignDns1 fill:#e1f5ff,color:#000
    style OB_SignDns2 fill:#e1f5ff,color:#000
    style OB_SignDnsN fill:#e1f5ff,color:#000
    style OB_SignP2p1 fill:#e1f5ff,color:#000
    style OB_SignP2p2 fill:#e1f5ff,color:#000
    style OB_SignP2pN fill:#e1f5ff,color:#000

    style CT_Upload1 fill:#e1f5ff,color:#000
    style CT_Upload2 fill:#e1f5ff,color:#000
    style CT_UploadN fill:#e1f5ff,color:#000
    style CT_SignSub1 fill:#e1f5ff,color:#000
    style CT_SignSub2 fill:#e1f5ff,color:#000
    style CT_SignSubN fill:#e1f5ff,color:#000

    %% Coordinator-only operations (pink)
    style OB_CreateProposals fill:#ffe1f5,color:#000
    style OB_SubmitDns fill:#ffe1f5,color:#000
    style OB_SubmitFinal fill:#ffe1f5,color:#000

    style CT_PrepareSubmissions fill:#ffe1f5,color:#000
    style CT_Execute fill:#ffe1f5,color:#000

    %% Collection points (yellow)
    style OB_CollectKeys fill:#fff4e1,color:#000
    style OB_CollectDns fill:#fff4e1,color:#000
    style OB_CollectP2p fill:#fff4e1,color:#000

    style CT_CollectAcks fill:#fff4e1,color:#000
    style CT_CollectSigs fill:#fff4e1,color:#000

    %% Phase headers (green)
    style OB_Phase1 fill:#d4edda,color:#000
    style OB_Phase2 fill:#d4edda,color:#000
    style OB_Phase3 fill:#d4edda,color:#000
    style OB_Phase4 fill:#d4edda,color:#000

    style CT_Phase1 fill:#d4edda,color:#000
    style CT_Phase2 fill:#d4edda,color:#000
    style CT_Phase3 fill:#d4edda,color:#000
    style CT_Phase4 fill:#d4edda,color:#000

    %% Kick workflow styling
    style KK_NoiseSetup fill:#ff9999,stroke:#cc0000,stroke-width:3px,color:#000
    style KK_Connect1 fill:#ffcccc,color:#000
    style KK_Connect2 fill:#ffcccc,color:#000
    style KK_Note fill:#ffeecc,color:#000
    style KK_AuthPeers fill:#ff9999,color:#000
    style KK_Disconnect fill:#ff9999,stroke:#cc0000,stroke-width:3px,color:#000

    style KK_DistKick fill:#99ccff,stroke:#0066cc,stroke-width:2px,color:#000

    style KK_SendKick1 fill:#ccffcc,stroke:#009900,stroke-width:2px,color:#000
    style KK_SendKickN fill:#ccffcc,stroke:#009900,stroke-width:2px,color:#000

    style KK_SignKick1 fill:#e1f5ff,color:#000
    style KK_SignKickN fill:#e1f5ff,color:#000

    style KK_ExportState fill:#ffe1f5,color:#000
    style KK_CreateProposals fill:#ffe1f5,color:#000
    style KK_SubmitKick fill:#ffe1f5,color:#000

    style KK_CollectKick fill:#fff4e1,color:#000

    style KK_Phase1 fill:#d4edda,color:#000
    style KK_Phase2 fill:#d4edda,color:#000
    style KK_Phase3 fill:#d4edda,color:#000

    %% Workflow start nodes (purple)
    style OnboardingStart fill:#e6ccff,stroke:#9933ff,stroke-width:2px,color:#000
    style ContractsStart fill:#e6ccff,stroke:#9933ff,stroke-width:2px,color:#000
    style KickStart fill:#e6ccff,stroke:#9933ff,stroke-width:2px,color:#000
    style ChooseWorkflow fill:#e6ccff,stroke:#9933ff,stroke-width:2px,color:#000
