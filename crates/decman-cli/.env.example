# decman API base URL
DECMAN_API_URL=http://localhost:8081

# Frontend credentials — the same username/password you log into the web UI with.
# decman-cli authenticates via the OAuth2 password grant, like the frontend.
DECMAN_USERNAME=alice
DECMAN_PASSWORD=change-me

# The token endpoint and client id are auto-discovered from the API's
# /auth-config (just like the frontend), so the settings below are optional.
# Set them only to override discovery.
#
#   Keycloak token URL: https://<host>/realms/<realm>/protocol/openid-connect/token
#   Auth0 token URL:    https://<tenant>/oauth/token
# OAUTH_TOKEN_URL=
# OAUTH_CLIENT_ID=

# Optional: only for confidential clients (public SPA clients omit this).
# OAUTH_CLIENT_SECRET=

# Optional: required by some IdPs (e.g. Auth0).
# OAUTH_AUDIENCE=

# Optional: space-separated scopes.
# OAUTH_SCOPE=
